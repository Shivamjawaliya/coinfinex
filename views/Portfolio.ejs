<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Virtual Trading — StockApp</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root {
      --bg:#03040a; --neon:#00f5c4; --neon2:#7b61ff; --neon3:#ff6b6b;
      --text:#f0f0f0; --muted:rgba(240,240,240,0.5);
      --surface:rgba(255,255,255,0.03); --surface2:rgba(255,255,255,0.055);
      --border:rgba(255,255,255,0.07); --border-h:rgba(0,245,196,0.22);
      --up:#00e676; --dn:#ff6b6b; --amber:#ffb800;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;overflow-x:hidden;}
    body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden;cursor:none;min-height:100vh;}

    /* ── Cursor ─────────────────────────────── */
    #cursor{position:fixed;width:10px;height:10px;border-radius:50%;background:var(--neon);pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:width .15s,height .15s;mix-blend-mode:difference;}
    #cursor-ring{position:fixed;width:36px;height:36px;border-radius:50%;border:1.5px solid var(--neon);pointer-events:none;z-index:99998;transform:translate(-50%,-50%);opacity:.5;transition:width .2s,height .2s;}

    /* ── BG ──────────────────────────────────── */
    #particle-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}
    .grid-lines{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(0,245,196,0.028) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,196,0.028) 1px,transparent 1px);background-size:80px 80px;animation:gridMove 25s linear infinite;}
    @keyframes gridMove{0%{background-position:0 0}100%{background-position:80px 80px}}
    .aurora{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
    .blob{position:absolute;border-radius:50%;filter:blur(100px);opacity:.15;animation:float 15s infinite alternate;}
    .blob:nth-child(1){width:600px;height:600px;background:var(--neon2);top:-100px;left:-100px;animation-duration:15s;}
    .blob:nth-child(2){width:500px;height:500px;background:var(--neon);bottom:-100px;right:-100px;animation-duration:18s;animation-delay:-5s;}
    .blob:nth-child(3){width:400px;height:350px;background:var(--neon3);top:50%;left:30%;animation-duration:12s;animation-delay:-9s;}
    @keyframes float{0%{transform:translate(0,0) scale(1)}50%{transform:translate(80px,60px) scale(1.08)}100%{transform:translate(-40px,40px) scale(.95)}}

    /* ── Nav ─────────────────────────────────── */
    nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:0 2%;backdrop-filter:blur(20px);background:rgba(0,0,0,.5);border-bottom:1px solid var(--border);height:60px;animation:navIn .6s ease both;}
    @keyframes navIn{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
    .nav-left{display:flex;align-items:center;}
    .nav-brand{display:flex;align-items:center;gap:10px;padding:0 20px;border-right:1px solid var(--border);height:60px;text-decoration:none;}
    .nav-brand-icon{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-family:'Syne';font-size:.8rem;font-weight:800;color:#03040a;}
    .nav-brand-text{font-family:'Syne';font-size:1rem;font-weight:800;color:var(--text);}
    .nav-tabs{display:flex;align-items:center;height:60px;}
    .nav-tab{display:flex;align-items:center;height:100%;padding:0 22px;text-decoration:none;font-size:.88rem;color:var(--muted);border-bottom:2px solid transparent;transition:color .25s,border-color .25s;white-space:nowrap;}
    .nav-tab:hover{color:var(--text);}
    .nav-tab.active{color:var(--neon);border-bottom-color:var(--neon);}
    .nav-right{display:flex;align-items:center;gap:10px;}
    .nav-divider{width:1px;height:28px;background:var(--border);}
    .tb-user{display:flex;align-items:center;gap:10px;padding:6px 14px 6px 8px;background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:8px;cursor:none;transition:all .25s;text-decoration:none;}
    .tb-user:hover{border-color:var(--neon);}
    .tb-avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;color:#03040a;flex-shrink:0;}
    .tb-name{font-size:.82rem;color:var(--text);}
    .nav-logout{width:36px;height:36px;border-radius:8px;background:rgba(255,107,107,.08);border:1px solid rgba(255,107,107,.2);display:flex;align-items:center;justify-content:center;cursor:none;transition:all .25s;color:var(--neon3);text-decoration:none;}
    .nav-logout:hover{background:rgba(255,107,107,.15);border-color:var(--neon3);}

    /* ── Page ────────────────────────────────── */
    .page{position:relative;z-index:1;padding:76px 32px 60px;max-width:1400px;margin:0 auto;}

    /* ── Top Banner ──────────────────────────── */
    .top-banner{
      background:linear-gradient(135deg,rgba(0,245,196,0.06),rgba(123,97,255,0.06));
      border:1px solid rgba(0,245,196,0.18);
      border-radius:20px;padding:28px 32px;
      margin-bottom:28px;
      display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;
      animation:fadeUp .7s ease both;
      position:relative;overflow:hidden;
    }
    .top-banner::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 10% 50%,rgba(0,245,196,0.04),transparent 60%);pointer-events:none;}
    .banner-left{}
    .banner-title{font-family:'Syne';font-size:1.5rem;font-weight:800;margin-bottom:4px;background:linear-gradient(135deg,var(--text),var(--neon));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
    .banner-sub{font-size:.88rem;color:var(--muted);}
    .banner-badge{display:flex;align-items:center;gap:8px;padding:10px 18px;border-radius:10px;background:rgba(0,245,196,.08);border:1px solid rgba(0,245,196,.25);font-size:.82rem;color:var(--neon);font-weight:600;}
    .live-dot{width:8px;height:8px;border-radius:50%;background:var(--neon);animation:pulse 1.8s infinite;}
    @keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,245,196,.4)}50%{opacity:.7;box-shadow:0 0 0 6px rgba(0,245,196,0)}}

    /* ── Stat cards ──────────────────────────── */
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-bottom:24px;}
    .stat-card{
      background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:24px;
      position:relative;overflow:hidden;
      transition:transform .3s,border-color .3s,box-shadow .3s;
      animation:fadeUp .7s ease calc(var(--d,.1s)) both;opacity:0;
    }
    .stat-card::before{content:'';position:absolute;top:-60px;right:-60px;width:150px;height:150px;border-radius:50%;background:radial-gradient(circle,var(--glow,rgba(0,245,196,.12)),transparent 70%);filter:blur(20px);}
    .stat-card:hover{transform:translateY(-4px);border-color:var(--border-h);box-shadow:0 20px 50px rgba(0,0,0,.4);}
    .stat-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:16px;font-size:1.1rem;}
    .stat-label{font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
    .stat-value{font-family:'Syne';font-size:2rem;font-weight:800;line-height:1;}
    .stat-sub{font-size:.78rem;color:var(--muted);margin-top:6px;}
    .stat-value.up{color:var(--up);}
    .stat-value.dn{color:var(--dn);}
    .stat-value.amber{color:var(--amber);}

    /* ── Layout ──────────────────────────────── */
    .layout{display:grid;grid-template-columns:1fr 340px;gap:20px;margin-bottom:24px;}

    /* ── Glass panel ─────────────────────────── */
    .panel{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:24px;animation:fadeUp .7s ease .3s both;opacity:0;}
    .panel-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;}
    .panel-title{font-family:'Syne';font-size:1.1rem;font-weight:800;}

    /* ── Table ───────────────────────────────── */
    .table-wrap{overflow-x:auto;}
    table{width:100%;border-collapse:collapse;font-size:.875rem;}
    th{padding:12px 14px;text-align:left;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);border-bottom:1px solid var(--border);font-weight:500;}
    td{padding:14px;border-bottom:1px solid rgba(255,255,255,.04);vertical-align:middle;}
    tr:last-child td{border-bottom:none;}
    tr:hover td{background:rgba(255,255,255,.025);}
    .asset-cell{display:flex;align-items:center;gap:12px;}
    .asset-logo{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:'Syne';font-size:.72rem;font-weight:800;color:#03040a;flex-shrink:0;}
    .asset-sym{font-family:'Syne';font-size:.9rem;font-weight:800;}
    .asset-name{font-size:.72rem;color:var(--muted);margin-top:2px;}
    .profit{color:var(--up);font-weight:700;}
    .loss{color:var(--dn);font-weight:700;}
    .pct-badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:999px;font-size:.75rem;font-weight:700;}
    .pct-badge.up{background:rgba(0,230,118,.12);color:var(--up);}
    .pct-badge.dn{background:rgba(255,107,107,.12);color:var(--dn);}

    /* ── Buttons ─────────────────────────────── */
    .sell-btn{
      padding:8px 16px;border:none;border-radius:10px;
      background:linear-gradient(135deg,rgba(255,77,109,.15),rgba(123,97,255,.15));
      border:1px solid rgba(255,77,109,.35);
      color:var(--neon3);font-family:'DM Sans';font-size:.78rem;font-weight:700;
      cursor:none;transition:all .25s;letter-spacing:.5px;white-space:nowrap;
    }
    .sell-btn:hover{background:linear-gradient(135deg,rgba(255,77,109,.28),rgba(123,97,255,.28));transform:translateY(-1px);box-shadow:0 8px 24px rgba(255,77,109,.2);}
    .buy-btn{
      padding:8px 16px;border:none;border-radius:10px;
      background:linear-gradient(135deg,rgba(0,245,196,.12),rgba(123,97,255,.12));
      border:1px solid rgba(0,245,196,.3);
      color:var(--neon);font-family:'DM Sans';font-size:.78rem;font-weight:700;
      cursor:none;transition:all .25s;letter-spacing:.5px;
    }
    .buy-btn:hover{background:linear-gradient(135deg,rgba(0,245,196,.22),rgba(123,97,255,.22));transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,245,196,.15);}

    /* ── Right panel ─────────────────────────── */
    .right-col{display:flex;flex-direction:column;gap:20px;}
    .chart-panel{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:24px;animation:fadeUp .7s ease .4s both;opacity:0;}
    .chart-wrap{position:relative;height:220px;}

    /* ── Recent activities ───────────────────── */
    .recent-panel{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:24px;animation:fadeUp .7s ease .5s both;opacity:0;}
    .recent-item{
      padding:14px 16px;border-radius:14px;
      background:rgba(255,255,255,.03);border:1px solid var(--border);
      margin-bottom:10px;transition:border-color .25s,background .25s;
      display:flex;align-items:center;gap:14px;
    }
    .recent-item:last-child{margin-bottom:0;}
    .recent-item:hover{border-color:rgba(0,245,196,.2);background:rgba(0,245,196,.03);}
    .recent-icon{width:34px;height:34px;border-radius:9px;background:rgba(0,245,196,.1);border:1px solid rgba(0,245,196,.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.85rem;}
    .recent-info{flex:1;}
    .recent-main{font-size:.85rem;line-height:1.4;}
    .recent-main strong{color:var(--neon);}
    .recent-time{font-size:.72rem;color:var(--muted);margin-top:2px;}
    .recent-amt{font-family:'Syne';font-size:.88rem;font-weight:700;color:var(--up);white-space:nowrap;}

    /* ── Quick buy section ───────────────────── */
    .quick-section{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:24px;animation:fadeUp .7s ease .35s both;opacity:0;margin-bottom:24px;}
    .quick-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-top:16px;}
    .quick-card{
      background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:14px;
      padding:14px;cursor:none;transition:all .25s;text-align:center;
    }
    .quick-card:hover{border-color:rgba(0,245,196,.3);background:rgba(0,245,196,.04);transform:translateY(-2px);}
    .quick-sym{font-family:'Syne';font-size:.95rem;font-weight:800;color:var(--neon);margin-bottom:4px;}
    .quick-price{font-size:.8rem;color:var(--muted);}
    .quick-chg{font-size:.75rem;font-weight:600;}
    .quick-chg.up{color:var(--up);}
    .quick-chg.dn{color:var(--dn);}

    /* ── Loader ──────────────────────────────── */
    #loader{display:none;position:fixed;inset:0;background:rgba(3,4,10,.88);z-index:2000;justify-content:center;align-items:center;flex-direction:column;gap:20px;backdrop-filter:blur(8px);}
    #loader.show{display:flex;}
    .loader-ring{width:56px;height:56px;border:2px solid var(--border);border-top-color:var(--neon);border-radius:50%;animation:spin .8s linear infinite;}
    @keyframes spin{to{transform:rotate(360deg)}}
    .loader-text{font-size:.75rem;letter-spacing:3px;color:var(--neon);text-transform:uppercase;}

    /* ── Modal ───────────────────────────────── */
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:9999;display:flex;justify-content:center;align-items:center;backdrop-filter:blur(12px);animation:fadeIn .2s ease;}
    @keyframes fadeIn{from{opacity:0}to{opacity:1}}
    .modal-box{width:440px;background:#0a0e1a;border:1px solid rgba(255,255,255,.1);border-radius:24px;padding:30px;color:var(--text);animation:slideUp .25s ease;}
    @keyframes slideUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    .modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;}
    .modal-title{font-family:'Syne';font-size:1.5rem;font-weight:800;}
    .modal-close{width:36px;height:36px;border:none;border-radius:10px;background:rgba(255,255,255,.06);color:var(--text);cursor:none;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:background .2s;}
    .modal-close:hover{background:rgba(255,255,255,.12);}
    .modal-field{background:rgba(255,255,255,.04);border-radius:14px;padding:16px;margin-bottom:14px;}
    .modal-field-label{font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:8px;}
    .modal-field-value{font-family:'Syne';font-size:1.4rem;font-weight:800;color:var(--neon);}
    .modal-input{width:100%;padding:14px;border:1px solid var(--border);border-radius:12px;background:#111827;color:var(--text);font-family:'DM Sans';font-size:1rem;outline:none;transition:border-color .2s;}
    .modal-input:focus{border-color:var(--neon);}
    .modal-input-hint{font-size:.72rem;color:var(--muted);margin-top:8px;}
    .modal-total{display:flex;justify-content:space-between;align-items:center;padding:16px;border-radius:14px;background:linear-gradient(135deg,rgba(255,77,109,.06),rgba(123,97,255,.06));border:1px solid rgba(255,255,255,.06);margin-bottom:20px;}
    .modal-total-label{font-size:.85rem;color:var(--muted);}
    .modal-total-value{font-family:'Syne';font-size:1.6rem;font-weight:800;}
    .modal-confirm{width:100%;padding:15px;border:none;border-radius:14px;background:linear-gradient(135deg,#ff4d6d,#7b61ff);color:white;font-family:'DM Sans';font-weight:800;font-size:1rem;cursor:none;transition:all .25s;letter-spacing:.5px;}
    .modal-confirm:hover{transform:scale(1.02);box-shadow:0 12px 32px rgba(255,77,109,.3);}

    /* ── Notification ────────────────────────── */
    .notif{position:fixed;bottom:30px;left:50%;transform:translateX(-50%);padding:14px 24px;border-radius:14px;font-weight:700;z-index:999999;opacity:0;transition:opacity .4s;font-family:'DM Sans';font-size:.9rem;pointer-events:none;white-space:nowrap;}
    .notif.success{background:linear-gradient(135deg,rgba(0,245,196,.9),rgba(0,200,150,.9));color:#03040a;}
    .notif.error{background:linear-gradient(135deg,rgba(255,77,109,.9),rgba(123,97,255,.9));color:white;}

    /* ── Animations ──────────────────────────── */
    @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

    /* ── Empty state ─────────────────────────── */
    .empty{text-align:center;padding:60px 20px;color:var(--muted);}
    .empty-icon{font-size:3rem;margin-bottom:12px;opacity:.5;}
    .empty-text{font-size:.95rem;}

    /* ── Responsive ──────────────────────────── */
    @media(max-width:1100px){.layout{grid-template-columns:1fr;}}
    @media(max-width:768px){.page{padding:76px 16px 40px;}.stats{grid-template-columns:1fr 1fr;}.nav-tabs .nav-tab:not(.active){display:none;}}
    @media(max-width:480px){.stats{grid-template-columns:1fr;}}
  </style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-ring"></div>
<div class="grid-lines"></div>
<div class="aurora">
  <div class="blob"></div><div class="blob"></div><div class="blob"></div>
</div>
<canvas id="particle-canvas"></canvas>

<div id="loader"><div class="loader-ring"></div><div class="loader-text">Processing...</div></div>

<!-- ── Nav ─────────────────────────────────── -->
<nav>
  <div class="nav-left">
    <a href="/" class="nav-brand">
      <div class="nav-brand-icon">SM</div>
      <span class="nav-brand-text">StockMarket</span>
    </a>
    <div class="nav-tabs">
        <a href="/" class="nav-tab">Explore</a>
        <a href="/categories" class="nav-tab">Categories</a>
        <a href="/portfolio" class="nav-tab active">Portfolio</a>
        <a href="/news" class="nav-tab">News</a>
        <a href="/virtual-trading" class="nav-tab">Virtual Trading</a>
    </div>
  </div>
  <div class="nav-right">
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/" class="tb-user">
        <div class="tb-avatar"><%= user.email[0].toUpperCase() %></div>
        <span class="tb-name"><%= user.email %></span>
      </a>
      <div class="nav-divider"></div>
      <a href="/logout" class="nav-logout" title="Logout">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    <% } %>
  </div>
</nav>

<!-- ── Page ─────────────────────────────────── -->
<div class="page">

  <!-- Banner -->
  <div class="top-banner">
    <div class="banner-left">
      <div class="banner-title">Portfolio</div>
      <div class="banner-sub">Trade with simulated balance using real-time market data. Zero risk, real experience.</div>
    </div>
    <div class="banner-badge"><span class="live-dot"></span>Live Market Data</div>
  </div>

  <!-- Stat cards -->
  <%
    const isProfit = totalProfit >= 0;
  %>
  <div class="stats">
    <div class="stat-card" style="--d:.1s;--glow:rgba(0,245,196,.14)">
      <div class="stat-icon" style="background:rgba(0,245,196,.1);color:var(--neon)">💼</div>
      <div class="stat-label">Portfolio Value</div>
      <div class="stat-value">₹<%= totalPortfolioValue.toFixed(2) %></div>
      <div class="stat-sub">Total market value of holdings</div>
    </div>
    <div class="stat-card" style="--d:.18s;--glow:<%= isProfit ? 'rgba(0,230,118,.14)' : 'rgba(255,107,107,.14)' %>">
      <div class="stat-icon" style="background:<%= isProfit ? 'rgba(0,230,118,.1)' : 'rgba(255,107,107,.1)' %>;color:<%= isProfit ? 'var(--up)' : 'var(--dn)' %>"><%= isProfit ? '📈' : '📉' %></div>
      <div class="stat-label">Total P&amp;L</div>
      <div class="stat-value <%= isProfit ? 'up' : 'dn' %>"><%= isProfit ? '+' : '' %>₹<%= totalProfit.toFixed(2) %></div>
      <div class="stat-sub">Unrealised profit / loss</div>
    </div>
    <div class="stat-card" style="--d:.26s;--glow:<%= isProfit ? 'rgba(0,230,118,.14)' : 'rgba(255,107,107,.14)' %>">
      <div class="stat-icon" style="background:rgba(255,184,0,.1);color:var(--amber)">🎯</div>
      <div class="stat-label">Return %</div>
      <div class="stat-value <%= isProfit ? 'up' : 'dn' %>"><%= isProfit ? '+' : '' %><%= totalProfitPercent %>%</div>
      <div class="stat-sub">Overall portfolio return</div>
    </div>
    <div class="stat-card" style="--d:.34s;--glow:rgba(123,97,255,.14)">
      <div class="stat-icon" style="background:rgba(123,97,255,.1);color:var(--neon2)">🏦</div>
      <div class="stat-label">Holdings</div>
      <div class="stat-value" style="color:var(--neon2)"><%= portfolio.length %></div>
      <div class="stat-sub">Unique positions open</div>
    </div>
  </div>

  <!-- Quick buy bar -->
  <div class="quick-section">
    <div class="panel-head">
      <div class="panel-title">Quick Buy</div>
      <span style="font-size:.78rem;color:var(--muted)">Click any stock to trade instantly</span>
    </div>
    <div class="quick-grid">
      <% const quickStocks = [
        {sym:'AAPL',price:'$212',chg:'+1.2%',up:true},
        {sym:'TSLA',price:'$248',chg:'+3.4%',up:true},
        {sym:'NVDA',price:'$875',chg:'+2.1%',up:true},
        {sym:'MSFT',price:'$415',chg:'-0.3%',up:false},
        {sym:'AMZN',price:'$191',chg:'+0.8%',up:true},
        {sym:'GOOGL',price:'$175',chg:'-0.5%',up:false},
        {sym:'META',price:'$512',chg:'+1.6%',up:true},
        {sym:'JPM', price:'$201',chg:'+0.4%',up:true},
      ]; %>
      <% quickStocks.forEach(s => { %>
      <div class="quick-card" onclick="openBuyModal('<%= s.sym %>')">
        <div class="quick-sym"><%= s.sym %></div>
        <div class="quick-price"><%= s.price %></div>
        <div class="quick-chg <%= s.up ? 'up' : 'dn' %>"><%= s.chg %></div>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Main layout -->
  <div class="layout">

    <!-- Left: Holdings + Recent -->
    <div style="display:flex;flex-direction:column;gap:20px;">

      <!-- Holdings table -->
      <div class="panel">
        <div class="panel-head">
          <div class="panel-title">Your Holdings</div>
          <% if(portfolio.length > 0) { %>
          <span style="font-size:.78rem;color:var(--muted);background:rgba(255,255,255,.05);border:1px solid var(--border);padding:4px 12px;border-radius:999px;"><%= portfolio.length %> positions</span>
          <% } %>
        </div>

        <% if(portfolio.length === 0) { %>
        <div class="empty">
          <div class="empty-icon">📂</div>
          <div class="empty-text">No holdings yet. Use Quick Buy above to start trading.</div>
        </div>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Asset</th>
                <th>Qty</th>
                <th>Buy Price</th>
                <th>Current</th>
                <th>Total Value</th>
                <th>P&amp;L</th>
                <th>Return</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% portfolio.forEach((item, idx) => {
                const logoColors = ['#00f5c4','#7b61ff','#ff6b6b','#ffb800','#00e676','#38bdf8'];
                const c = logoColors[idx % logoColors.length];
                const isUp = item.profit >= 0;
              %>
              <tr>
                <td>
                  <div class="asset-cell">
                    <div class="asset-logo" style="background:linear-gradient(135deg,<%= c %>,<%= c %>88)">
                      <%= item.stockname.slice(0,2).toUpperCase() %>
                    </div>
                    <div>
                      <div class="asset-sym"><%= item.stockname %></div>
                      <div class="asset-name">Virtual Position</div>
                    </div>
                  </div>
                </td>
                <td style="font-weight:600"><%= item.quantity %></td>
                <td>₹<%= item.buyPrice %></td>
                <td style="color:var(--neon);font-weight:600">₹<%= item.currentPrice.toFixed(2) %></td>
                <td style="font-weight:600">₹<%= (item.currentPrice * item.quantity).toFixed(2) %></td>
                <td class="<%= isUp ? 'profit' : 'loss' %>"><%= isUp ? '+' : '' %>₹<%= item.profit.toFixed(2) %></td>
                <td><span class="pct-badge <%= isUp ? 'up' : 'dn' %>"><%= isUp ? '▲' : '▼' %> <%= item.profitPercent %>%</span></td>
                <td>
                  <button class="sell-btn" onclick="sellStock('<%= item.stockname %>',<%= item.currentPrice %>,<%= item.quantity %>)">
                    Sell
                  </button>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

      <!-- Recent activities -->
      <div class="panel" style="animation-delay:.45s">
        <div class="panel-head">
          <div class="panel-title">Recent Activity</div>
          <span style="font-size:.72rem;color:var(--muted)"><%= recentActivities.length %> trades</span>
        </div>
        <% if(recentActivities.length === 0) { %>
        <div class="empty" style="padding:30px 20px">
          <div class="empty-icon">🕰️</div>
          <div class="empty-text">No recent activity.</div>
        </div>
        <% } else { %>
        <% recentActivities.forEach(item => { %>
        <div class="recent-item">
          <div class="recent-icon">📥</div>
          <div class="recent-info">
            <div class="recent-main">Bought <strong><%= item.stockquantity %> shares</strong> of <strong><%= item.stockname %></strong></div>
            <div class="recent-time">@ ₹<%= item.stockbuyprice %> per share</div>
          </div>
          <div class="recent-amt">₹<%= (item.stockquantity * item.stockbuyprice).toFixed(2) %></div>
        </div>
        <% }) %>
        <% } %>
      </div>

    </div>

    <!-- Right col -->
    <div class="right-col">

      <!-- Doughnut chart -->
      <div class="chart-panel">
        <div class="panel-head" style="margin-bottom:16px">
          <div class="panel-title">Asset Distribution</div>
        </div>
        <% if(assetDistribution.length === 0) { %>
        <div class="empty" style="padding:30px 20px"><div class="empty-icon">🥧</div><div class="empty-text">No assets yet.</div></div>
        <% } else { %>
        <div class="chart-wrap">
          <canvas id="assetChart"></canvas>
        </div>
        <% } %>
      </div>

      <!-- Portfolio breakdown -->
      <div class="panel" style="animation-delay:.5s">
        <div class="panel-head" style="margin-bottom:16px">
          <div class="panel-title">Breakdown</div>
        </div>
        <% if(portfolio.length === 0) { %>
        <div class="empty" style="padding:20px"><div class="empty-text">No holdings to show.</div></div>
        <% } else { %>
        <% portfolio.forEach((item, idx) => {
          const logoColors = ['#00f5c4','#7b61ff','#ff6b6b','#ffb800','#00e676','#38bdf8'];
          const c = logoColors[idx % logoColors.length];
          const pct = ((item.currentPrice * item.quantity) / totalPortfolioValue * 100).toFixed(1);
          const isUp = item.profit >= 0;
        %>
        <div style="margin-bottom:14px">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
            <div style="display:flex;align-items:center;gap:8px">
              <div style="width:10px;height:10px;border-radius:50%;background:<%= c %>"></div>
              <span style="font-size:.85rem;font-weight:600"><%= item.stockname %></span>
            </div>
            <span style="font-size:.82rem;color:var(--muted)"><%= pct %>%</span>
          </div>
          <div style="height:6px;background:rgba(255,255,255,.06);border-radius:3px;overflow:hidden">
            <div style="height:100%;width:<%= pct %>%;background:linear-gradient(90deg,<%= c %>,<%= c %>88);border-radius:3px;transition:width .6s ease"></div>
          </div>
        </div>
        <% }) %>
        <% } %>
      </div>

    </div>
  </div>

</div><!-- /.page -->

<!-- ── Scripts ──────────────────────────────── -->
<script>
/* Cursor */
(() => {
  const dot=document.getElementById('cursor'),ring=document.getElementById('cursor-ring');
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;dot.style.left=mx+'px';dot.style.top=my+'px';});
  (function loop(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loop);})();
  function attach(){
    document.querySelectorAll('a,button,.quick-card,.recent-item,.tb-user,.nav-logout,.sell-btn,.buy-btn,.modal-close,.modal-confirm').forEach(el=>{
      el.addEventListener('mouseenter',()=>{dot.style.width='20px';dot.style.height='20px';ring.style.width='52px';ring.style.height='52px';ring.style.opacity='.75';});
      el.addEventListener('mouseleave',()=>{dot.style.width='10px';dot.style.height='10px';ring.style.width='36px';ring.style.height='36px';ring.style.opacity='.5';});
    });
  }
  attach(); window._reattachCursor=attach;
})();

/* Particles */
(() => {
  const canvas=document.getElementById('particle-canvas'),ctx=canvas.getContext('2d');
  let W,H;
  function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;}
  resize();window.addEventListener('resize',resize);
  const PAL=['#00f5c4','#7b61ff','#ff6b6b','rgba(240,240,240,.4)'];
  const pts=Array.from({length:90},()=>({x:Math.random()*window.innerWidth,y:Math.random()*window.innerHeight,r:Math.random()*1.4+.3,vx:(Math.random()-.5)*.34,vy:(Math.random()-.5)*.34,a:Math.random()*.32+.07,col:PAL[Math.floor(Math.random()*PAL.length)]}));
  let pmx=-9999,pmy=-9999;
  document.addEventListener('mousemove',e=>{pmx=e.clientX;pmy=e.clientY;});
  (function draw(){
    ctx.clearRect(0,0,W,H);
    for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){
      const d=Math.hypot(pts[i].x-pts[j].x,pts[i].y-pts[j].y);
      if(d<90){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.strokeStyle='#00f5c4';ctx.globalAlpha=(1-d/90)*.055;ctx.lineWidth=.6;ctx.stroke();}
    }
    pts.forEach(p=>{
      const dx=p.x-pmx,dy=p.y-pmy,d=Math.hypot(dx,dy);
      if(d<110){const f=((110-d)/110)*.48;p.vx+=(dx/d)*f;p.vy+=(dy/d)*f;}
      p.vx*=.982;p.vy*=.982;p.x+=p.vx;p.y+=p.vy;
      if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.globalAlpha=p.a;ctx.fillStyle=p.col;ctx.fill();
    });
    ctx.globalAlpha=1;requestAnimationFrame(draw);
  })();
})();

/* Doughnut chart */
<% if(assetDistribution.length > 0) { %>
(function(){
  const data = <%- JSON.stringify(assetDistribution) %>;
  const ctx  = document.getElementById('assetChart');
  new Chart(ctx,{
    type:'doughnut',
    data:{
      labels:data.map(a=>a.name),
      datasets:[{
        data:data.map(a=>a.value),
        backgroundColor:['#00f5c4','#7b61ff','#ff6b6b','#ffb800','#00e676','#38bdf8'],
        borderColor:'rgba(0,0,0,0)',
        hoverOffset:8,
        borderRadius:4,
      }]
    },
    options:{
      responsive:true,
      maintainAspectRatio:false,
      cutout:'65%',
      plugins:{
        legend:{labels:{color:'rgba(240,240,240,.7)',font:{family:'DM Sans',size:12},padding:16}},
        tooltip:{backgroundColor:'#0a0e1a',borderColor:'rgba(255,255,255,.1)',borderWidth:1,titleColor:'#00f5c4',bodyColor:'#f0f0f0',padding:12}
      }
    }
  });
})();
<% } %>

/* ── Sell modal ──────────────────────────── */
function sellStock(stockname, currentPrice, maxQty) {
  document.getElementById('sellModal')?.remove();
  const overlay = document.createElement('div');
  overlay.id = 'sellModal';
  overlay.className = 'modal-overlay';
  overlay.innerHTML = `
    <div class="modal-box">
      <div class="modal-head">
        <div class="modal-title">Sell <span style="color:var(--neon3)">${stockname}</span></div>
        <button class="modal-close" id="closeModal">✕</button>
      </div>
      <div class="modal-field">
        <div class="modal-field-label">Current Price</div>
        <div class="modal-field-value">₹${currentPrice.toFixed(2)}</div>
      </div>
      <div class="modal-field">
        <div class="modal-field-label">Quantity to sell</div>
        <input type="number" id="sellQty" class="modal-input" min="1" max="${maxQty}" value="1"/>
        <div class="modal-input-hint">Available: ${maxQty} shares</div>
      </div>
      <div class="modal-total">
        <span class="modal-total-label">You will receive</span>
        <span class="modal-total-value" id="sellTotal">₹${currentPrice.toFixed(2)}</span>
      </div>
      <button class="modal-confirm" id="confirmSell">Confirm Sell</button>
    </div>`;
  document.body.appendChild(overlay);
  if(window._reattachCursor) window._reattachCursor();

  const qtyInput = document.getElementById('sellQty');
  qtyInput.addEventListener('input',()=>{
    const q = Math.min(parseInt(qtyInput.value)||1, maxQty);
    document.getElementById('sellTotal').textContent = '₹'+(q*currentPrice).toFixed(2);
  });
  document.getElementById('closeModal').onclick = () => overlay.remove();
  overlay.addEventListener('click', e => { if(e.target===overlay) overlay.remove(); });

  document.getElementById('confirmSell').onclick = async () => {
    const qty = parseInt(qtyInput.value)||1;
    if(qty > maxQty){ showNotif('You only have '+maxQty+' shares','error'); return; }
    document.getElementById('loader').classList.add('show');
    try {
      const r = await fetch('/sell-stock',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({stockname,stockquantity:qty})});
      const d = await r.json();
      document.getElementById('loader').classList.remove('show');
      if(d.success){overlay.remove();showNotif('✓ Sold '+qty+' share(s) of '+stockname,'success');setTimeout(()=>location.reload(),1200);}
      else showNotif('Sell failed — '+( d.message||'try again'),'error');
    } catch(err){ document.getElementById('loader').classList.remove('show'); showNotif('Network error','error'); }
  };
}

/* ── Buy modal ───────────────────────────── */
function openBuyModal(symbol) {
  document.getElementById('buyModal')?.remove();
  const overlay = document.createElement('div');
  overlay.id = 'buyModal';
  overlay.className = 'modal-overlay';
  overlay.innerHTML = `
    <div class="modal-box">
      <div class="modal-head">
        <div class="modal-title">Buy <span style="color:var(--neon)">${symbol}</span></div>
        <button class="modal-close" id="closeBuyModal">✕</button>
      </div>
      <div class="modal-field">
        <div class="modal-field-label">Symbol</div>
        <div class="modal-field-value">${symbol}</div>
      </div>
      <div class="modal-field">
        <div class="modal-field-label">Quantity</div>
        <input type="number" id="buyQty" class="modal-input" min="1" value="1"/>
        <div class="modal-input-hint">Enter how many shares you want to buy</div>
      </div>
      <div class="modal-total" style="background:linear-gradient(135deg,rgba(0,245,196,.06),rgba(123,97,255,.06))">
        <span class="modal-total-label">Estimated cost</span>
        <span class="modal-total-value" id="buyTotal" style="color:var(--neon)">Fetching...</span>
      </div>
      <button class="modal-confirm" id="confirmBuy" style="background:linear-gradient(135deg,#00f5c4,#7b61ff);color:#03040a;">Confirm Buy</button>
    </div>`;
  document.body.appendChild(overlay);
  if(window._reattachCursor) window._reattachCursor();

  let livePrice = 0;
  // Try to get live price
  fetch(`https://api.allorigins.win/raw?url=${encodeURIComponent('https://www.alphavantage.co/query?function=GLOBAL_QUOTE&symbol='+symbol+'&apikey=KFI0KFX5JDSP12Z5')}`)
    .then(r=>r.json()).then(d=>{
      const p = parseFloat(d['Global Quote']?.['05. price']||0);
      if(p){ livePrice=p; updateBuyTotal(); }
    }).catch(()=>{});

  function updateBuyTotal(){
    const q=parseInt(document.getElementById('buyQty')?.value)||1;
    document.getElementById('buyTotal').textContent = livePrice ? '₹'+(q*livePrice*83.5).toFixed(2) : 'Price unavailable';
  }
  document.getElementById('buyQty').addEventListener('input', updateBuyTotal);
  document.getElementById('closeBuyModal').onclick = () => overlay.remove();
  overlay.addEventListener('click', e=>{ if(e.target===overlay) overlay.remove(); });

  document.getElementById('confirmBuy').onclick = async () => {
    const qty = parseInt(document.getElementById('buyQty').value)||1;
    if(!livePrice){ showNotif('Could not fetch live price','error'); return; }
    document.getElementById('loader').classList.add('show');
    try {
      const r = await fetch('/buy-stock',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({stockname:symbol,stockquantity:qty,stockbuyprice:livePrice})});
      const d = await r.json();
      document.getElementById('loader').classList.remove('show');
      if(d.success){overlay.remove();showNotif('✓ Bought '+qty+' share(s) of '+symbol,'success');setTimeout(()=>location.reload(),1200);}
      else showNotif('Buy failed — '+(d.message||'try again'),'error');
    } catch(err){ document.getElementById('loader').classList.remove('show'); showNotif('Network error','error'); }
  };
}

/* ── Notification ────────────────────────── */
function showNotif(msg, type='success') {
  let n = document.getElementById('notif');
  if(!n){ n=document.createElement('div'); n.id='notif'; n.className='notif'; document.body.appendChild(n); }
  n.className='notif '+type;
  n.textContent=msg;
  n.style.opacity='1';
  clearTimeout(n._t);
  n._t=setTimeout(()=>n.style.opacity='0',3000);
}
</script>

</body>
</html>
