<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Categories — Coinfinex</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:#03040a; --neon:#00f5c4; --neon2:#7b61ff; --neon3:#ff6b6b;
      --text:#f0f0f0; --muted:rgba(240,240,240,0.5);
      --surface:rgba(255,255,255,0.03); --surface2:rgba(255,255,255,0.055);
      --border:rgba(255,255,255,0.07); --border-h:rgba(0,245,196,0.22);
      --up:#00e676; --dn:#ff6b6b;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;overflow-x:hidden;}
    body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden;cursor:none;min-height:100vh;}

    /* ── Cursor ─────────────────────────────── */
    #cursor{position:fixed;width:10px;height:10px;border-radius:50%;background:var(--neon);pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:width .15s,height .15s,background .2s;mix-blend-mode:difference;}
    #cursor-ring{position:fixed;width:36px;height:36px;border-radius:50%;border:1.5px solid var(--neon);pointer-events:none;z-index:99998;transform:translate(-50%,-50%);opacity:.5;transition:width .2s,height .2s;}

    /* ── BG effects ─────────────────────────── */
    #particle-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}
    .grid-lines{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(0,245,196,0.028) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,196,0.028) 1px,transparent 1px);background-size:80px 80px;animation:gridMove 25s linear infinite;}
    @keyframes gridMove{0%{background-position:0 0}100%{background-position:80px 80px}}
    .aurora{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
    .blob{position:absolute;border-radius:50%;filter:blur(100px);opacity:.15;animation:float 15s infinite alternate;}
    .blob:nth-child(1){width:600px;height:600px;background:var(--neon2);top:-100px;left:-100px;animation-duration:15s;}
    .blob:nth-child(2){width:500px;height:500px;background:var(--neon);bottom:-100px;right:-100px;animation-duration:18s;animation-delay:-5s;}
    .blob:nth-child(3){width:400px;height:350px;background:var(--neon3);top:50%;left:30%;animation-duration:12s;animation-delay:-9s;}
    @keyframes float{0%{transform:translate(0,0) scale(1)}50%{transform:translate(80px,60px) scale(1.08)}100%{transform:translate(-40px,40px) scale(.95)}}

    /* ── Nav ────────────────────────────────── */
    nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:0 2%;backdrop-filter:blur(20px);background:rgba(0,0,0,.5);border-bottom:1px solid var(--border);height:60px;animation:navIn .6s ease both;}
    @keyframes navIn{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
    .nav-left{display:flex;align-items:center;}
    .nav-brand{display:flex;align-items:center;gap:10px;padding:0 20px;border-right:1px solid var(--border);height:60px;text-decoration:none;}
    .nav-brand-icon{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-family:'Syne';font-size:.8rem;font-weight:800;color:#03040a;}
    .nav-brand-text{font-family:'Syne';font-size:1rem;font-weight:800;color:var(--text);}
    .nav-tabs{display:flex;align-items:center;height:60px;}
    .nav-tab{display:flex;align-items:center;height:100%;padding:0 24px;text-decoration:none;font-size:.88rem;color:var(--muted);border-bottom:2px solid transparent;transition:color .25s,border-color .25s;white-space:nowrap;}
    .nav-tab:hover{color:var(--text);}
    .nav-tab.active{color:var(--neon);border-bottom-color:var(--neon);}
    .nav-right{display:flex;align-items:center;gap:10px;}
    .nav-divider{width:1px;height:28px;background:var(--border);}
    .tb-user{display:flex;align-items:center;gap:10px;padding:6px 14px 6px 8px;background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:8px;cursor:none;transition:all .25s;text-decoration:none;}
    .tb-user:hover{border-color:var(--neon);}
    .tb-avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;color:#03040a;flex-shrink:0;}
    .tb-name{font-size:.82rem;color:var(--text);}
    .nav-logout{width:36px;height:36px;border-radius:8px;background:rgba(255,107,107,.08);border:1px solid rgba(255,107,107,.2);display:flex;align-items:center;justify-content:center;cursor:none;transition:all .25s;color:var(--neon3);text-decoration:none;}
    .nav-logout:hover{background:rgba(255,107,107,.15);border-color:var(--neon3);}

    /* ── Page ───────────────────────────────── */
    .page{position:relative;z-index:1;padding:80px 0 60px;min-height:100vh;}
    .container{max-width:1400px;margin:0 auto;padding:0 32px;}

    /* ── Page header ────────────────────────── */
    .page-header{padding:32px 32px 0;max-width:1400px;margin:0 auto;animation:fadeUp .7s ease both;}
    .page-title{font-family:'Syne';font-size:1.8rem;font-weight:800;margin-bottom:6px;background:linear-gradient(135deg,var(--text),var(--neon),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
    .page-sub{font-size:.9rem;color:var(--muted);margin-bottom:28px;}

    /* ── Toolbar ────────────────────────────── */
    .toolbar{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:16px 20px;display:flex;align-items:center;gap:12px;flex-wrap:wrap;animation:fadeUp .7s .1s ease both;opacity:0;position:sticky;top:68px;z-index:90;backdrop-filter:blur(16px);}
    .toolbar-label{font-size:.7rem;font-weight:700;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;white-space:nowrap;}

    /* dropdown */
    .select-wrap{position:relative;display:flex;align-items:center;}
    .select-wrap::after{content:'▾';position:absolute;right:.75rem;color:var(--muted);pointer-events:none;font-size:.8rem;}
    .cat-select{appearance:none;background:rgba(0,0,0,.4);border:1px solid var(--border);border-radius:10px;color:var(--text);font-family:'DM Sans';font-size:.875rem;font-weight:600;padding:.45rem 2.2rem .45rem .85rem;cursor:none;outline:none;transition:all .25s;min-width:230px;}
    .cat-select:focus{border-color:var(--neon);box-shadow:0 0 20px rgba(0,245,196,.1);}
    .cat-select option{background:#0d0f1a;}

    /* pills */
    .cat-pills{display:flex;gap:.4rem;flex-wrap:wrap;}
    .cat-pill{display:inline-flex;align-items:center;gap:.3rem;padding:.3rem .9rem;border-radius:999px;border:1px solid var(--border);background:transparent;color:var(--muted);font-family:'DM Sans';font-size:.78rem;font-weight:600;cursor:none;text-decoration:none;transition:all .2s;}
    .cat-pill:hover,.cat-pill.active{border-color:rgba(0,245,196,.45);color:var(--neon);background:rgba(0,245,196,.08);text-decoration:none;}

    /* ── Summary bar ────────────────────────── */
    .summary-bar{display:flex;gap:1.5rem;flex-wrap:wrap;padding:20px 32px;max-width:1400px;margin:0 auto;animation:fadeUp .7s .18s ease both;opacity:0;}
    .sum-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:16px 20px;display:flex;flex-direction:column;gap:4px;transition:border-color .25s,transform .25s;}
    .sum-card:hover{border-color:var(--border-h);transform:translateY(-2px);}
    .sum-label{font-size:.68rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;}
    .sum-value{font-family:'Syne';font-size:1.5rem;font-weight:800;color:var(--neon);}
    .sum-value.colored{color:var(--card-color,var(--neon));}

    /* ── Category sections ──────────────────── */
    .cat-section{padding:0 32px;max-width:1400px;margin:0 auto 4rem;scroll-margin-top:140px;}
    .section-head{display:flex;align-items:center;gap:14px;margin-bottom:1.4rem;padding-bottom:1rem;border-bottom:1px solid var(--border);position:relative;}
    .section-head::after{content:'';position:absolute;bottom:-1px;left:0;width:60px;height:2px;background:var(--sec-color,var(--neon));border-radius:2px;}
    .section-emoji{font-size:2rem;line-height:1;}
    .section-info{flex:1;}
    .section-title{font-family:'Syne';font-size:1.15rem;font-weight:800;margin-bottom:.2rem;}
    .section-desc{font-size:.8rem;color:var(--muted);}
    .section-count{font-size:.72rem;font-weight:700;padding:.22rem .7rem;border-radius:999px;background:rgba(255,255,255,.05);border:1px solid var(--border);color:var(--muted);}

    /* ── Stock cards ────────────────────────── */
    .cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;}
    .stock-card{background:var(--surface);border:1px solid var(--border);border-radius:18px;padding:20px;cursor:none;position:relative;overflow:hidden;transition:transform .35s,border-color .35s,box-shadow .35s;text-decoration:none;color:var(--text);display:flex;flex-direction:column;gap:.4rem;animation:fadeUp .6s ease calc(var(--i,0)*.055s) both;opacity:0;}
    .stock-card::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at 80% 10%,rgba(0,245,196,.06),transparent 65%);opacity:0;transition:opacity .3s;}
    .stock-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--c-accent,var(--neon)),transparent);opacity:0;transition:opacity .3s;}
    .stock-card:hover::before,.stock-card:hover::after{opacity:1;}
    .stock-card:hover{transform:translateY(-5px);border-color:var(--border-h);box-shadow:0 24px 64px rgba(0,0,0,.5);text-decoration:none;}

    .card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
    .card-logo{width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,var(--c-accent,var(--neon)),var(--neon2));display:flex;align-items:center;justify-content:center;font-family:'Syne';font-size:1rem;font-weight:800;color:#03040a;flex-shrink:0;}
    .card-exchange{font-size:.68rem;font-weight:700;padding:.15rem .5rem;border-radius:6px;background:rgba(255,255,255,.05);border:1px solid var(--border);color:var(--muted);}
    .card-sym{font-family:'Syne';font-size:1.05rem;font-weight:800;}
    .card-name{font-size:.72rem;color:var(--muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .card-desc{font-size:.74rem;color:var(--muted);line-height:1.5;}
    .card-footer{display:flex;align-items:center;justify-content:space-between;margin-top:6px;padding-top:10px;border-top:1px solid var(--border);}
    .card-cap{font-size:.68rem;font-weight:700;padding:.15rem .55rem;border-radius:999px;background:rgba(255,255,255,.05);border:1px solid var(--border);color:var(--muted);}
    .card-arrow{font-size:.85rem;color:var(--muted);transition:color .2s,transform .2s;}
    .stock-card:hover .card-arrow{color:var(--c-accent,var(--neon));transform:translateX(4px);}

    /* ── Back to top ────────────────────────── */
    .back-top{display:inline-flex;align-items:center;gap:.4rem;font-size:.78rem;color:var(--muted);cursor:none;margin-top:12px;border:none;background:none;padding:0;text-decoration:none;transition:color .2s;}
    .back-top:hover{color:var(--neon);text-decoration:none;}

    /* ── Animations ─────────────────────────── */
    @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

    /* ── Responsive ─────────────────────────── */
    @media(max-width:1100px){.cards-grid{grid-template-columns:repeat(auto-fill,minmax(200px,1fr));}}
    @media(max-width:900px){.nav-tabs .nav-tab:not(.active){display:none;}.cat-pills{display:none;}}
    @media(max-width:600px){.cards-grid{grid-template-columns:1fr 1fr;}.summary-bar{gap:.75rem;}.page-header,.cat-section,.summary-bar{padding-left:16px;padding-right:16px;}}
    @media(max-width:380px){.cards-grid{grid-template-columns:1fr;}}
  </style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-ring"></div>
<div class="grid-lines"></div>
<div class="aurora">
  <div class="blob"></div><div class="blob"></div><div class="blob"></div>
</div>
<canvas id="particle-canvas"></canvas>

<!-- ── Nav ─────────────────────────────────── -->
<nav id="navbar">
  <div class="nav-left">
    <a href="/" class="nav-brand">
      <div class="nav-brand-icon">CF</div>
      <span class="nav-brand-text">Coinfinex</span>
    </a>
    <div class="nav-tabs">
      <a href="/" class="nav-tab ">Explore</a>
      <a href="/categories" class="nav-tab active">Categories</a>
      <a href="/portfolio" class="nav-tab">Portfolio</a>
      <a href="/news" class="nav-tab">News</a>
      <a href="/virtual-trading" class="nav-tab">Virtual Trading</a>
    </div>
  </div>
  <div class="nav-right">
    <% if (typeof user !== 'undefined' && user && (user.username || user.email)) { %>
      <a href="/dashboard/<%= encodeURIComponent(user.username || user.email) %>" class="tb-user">
        <div class="tb-avatar">
          <%= (user.username && user.username[0] ? user.username[0].toUpperCase() : (user.email && user.email[0] ? user.email[0].toUpperCase() : 'U')) %>
        </div>
        <span class="tb-name"><%= user.username || user.email %></span>
      </a>
      <a href="/logout" class="nav-logout" title="Logout">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    <% } else { %>
      <a href="/login" style="padding:8px 18px;border-radius:8px;border:1px solid rgba(255,255,255,0.2);color:var(--text);font-size:0.85rem;text-decoration:none;transition:all .25s;" onmouseenter="this.style.borderColor='var(--neon)';this.style.color='var(--neon)'" onmouseleave="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='var(--text)'">Login</a>
      <a href="/signup" style="padding:8px 18px;border-radius:8px;background:linear-gradient(135deg,var(--neon),var(--neon2));color:#000;font-size:0.85rem;font-weight:700;text-decoration:none;transition:transform .2s;" onmouseenter="this.style.transform='scale(1.05)'" onmouseleave="this.style.transform='scale(1)'">Sign Up</a>
    <% } %>
  </div>
</nav>

<!-- ── Page ─────────────────────────────────── -->
<div class="page" id="top">

  <!-- Header + toolbar -->
  <div class="page-header">
    <h1 class="page-title">Stock Categories</h1>
    <p class="page-sub">Browse <%= categories.reduce((s,c)=>s+c.stocks.length,0) %> stocks across <%= categories.length %> industry sectors. Click any card for a live quote, chart &amp; news.</p>

    <div class="toolbar" id="toolbar">
      <!-- <span class="toolbar-label">Jump to:</span>

      <div class="select-wrap">
        <select class="cat-select" id="catSelect" onchange="jumpTo(this.value)">
          <option value="">— Select a sector —</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>"><%= cat.emoji %> &nbsp;<%= cat.label %> (<%= cat.stocks.length %>)</option>
          <% }) %>
        </select>
      </div> -->
        <% categories.forEach(cat => { %>
          <a class="cat-pill" href="#<%= cat.id %>" data-id="<%= cat.id %>"><%= cat.emoji %> <%= cat.label %></a>
        <% }) %>
      
    </div>

  </div>

  <!-- Summary bar -->
  <% const total = categories.reduce((s,c)=>s+c.stocks.length,0); %>
  <div class="summary-bar">
    <div class="sum-card">
      <span class="sum-label">Total Stocks</span>
      <span class="sum-value"><%= total %></span>
    </div>
    <div class="sum-card">
      <span class="sum-label">Sectors</span>
      <span class="sum-value"><%= categories.length %></span>
    </div>
    <% categories.forEach(cat => { %>
    <div class="sum-card" style="--card-color:<%= cat.color %>">
      <span class="sum-label"><%= cat.emoji %> <%= cat.label %></span>
      <span class="sum-value colored"><%= cat.stocks.length %></span>
    </div>
    <% }) %>
  </div>

  <!-- ── Sections ──────────────────────────── -->
  <% categories.forEach(cat => { %>
  <section class="cat-section" id="<%= cat.id %>">

    <div class="section-head" style="--sec-color:<%= cat.color %>">
      <span class="section-emoji"><%= cat.emoji %></span>
      <div class="section-info">
        <div class="section-title" style="color:<%= cat.color %>"><%= cat.label %></div>
        <div class="section-desc"><%= cat.description %></div>
      </div>
      <span class="section-count"><%= cat.stocks.length %> stocks</span>
    </div>

    <div class="cards-grid">
      <% cat.stocks.forEach((stock, idx) => { %>
      <a class="stock-card"
         href="/stock/<%= stock.sym %>"
         style="--i:<%= idx %>;--c-accent:<%= cat.color %>"
         title="<%= stock.name %>">
        <div class="card-head">
          <div class="card-logo" style="background:linear-gradient(135deg,<%= cat.color %>,<%= cat.color %>88)">
            <%= stock.sym.slice(0,2) %>
          </div>
          <span class="card-exchange"><%= stock.exchange %></span>
        </div>
        <div class="card-sym"><%= stock.sym %></div>
        <div class="card-name"><%= stock.name %></div>
        <div class="card-desc"><%= stock.desc %></div>
        <div class="card-footer">
          <span class="card-cap"><%= stock.cap %></span>
          <span class="card-arrow">→</span>
        </div>
      </a>
      <% }) %>
    </div>

    <a href="#top" class="back-top">↑ Back to top</a>
  </section>
  <% }) %>

</div><!-- /.page -->

<!-- ── Scripts ──────────────────────────────── -->
<script>
/* Cursor */
(() => {
  const dot=document.getElementById('cursor'),ring=document.getElementById('cursor-ring');
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;dot.style.left=mx+'px';dot.style.top=my+'px';});
  (function loop(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loop);})();
  function attach(){
    document.querySelectorAll('a,button,.stock-card,.cat-pill,.cat-select,.tb-user,.nav-logout').forEach(el=>{
      el.addEventListener('mouseenter',()=>{dot.style.width='20px';dot.style.height='20px';ring.style.width='52px';ring.style.height='52px';ring.style.opacity='.75';});
      el.addEventListener('mouseleave',()=>{dot.style.width='10px';dot.style.height='10px';ring.style.width='36px';ring.style.height='36px';ring.style.opacity='.5';});
    });
  }
  attach();
})();

/* Particles */
(() => {
  const canvas=document.getElementById('particle-canvas'),ctx=canvas.getContext('2d');
  let W,H;
  function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;}
  resize();window.addEventListener('resize',resize);
  const PAL=['#00f5c4','#7b61ff','#ff6b6b','rgba(240,240,240,0.4)'];
  const pts=Array.from({length:110},()=>({x:Math.random()*window.innerWidth,y:Math.random()*window.innerHeight,r:Math.random()*1.4+.3,vx:(Math.random()-.5)*.36,vy:(Math.random()-.5)*.36,a:Math.random()*.35+.07,col:PAL[Math.floor(Math.random()*PAL.length)]}));
  let pmx=-9999,pmy=-9999;
  document.addEventListener('mousemove',e=>{pmx=e.clientX;pmy=e.clientY;});
  (function draw(){
    ctx.clearRect(0,0,W,H);
    for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){
      const d=Math.hypot(pts[i].x-pts[j].x,pts[i].y-pts[j].y);
      if(d<100){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.strokeStyle='#00f5c4';ctx.globalAlpha=(1-d/100)*.06;ctx.lineWidth=.65;ctx.stroke();}
    }
    pts.forEach(p=>{
      const dx=p.x-pmx,dy=p.y-pmy,d=Math.hypot(dx,dy);
      if(d<110){const f=((110-d)/110)*.5;p.vx+=(dx/d)*f;p.vy+=(dy/d)*f;}
      p.vx*=.982;p.vy*=.982;p.x+=p.vx;p.y+=p.vy;
      if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.globalAlpha=p.a;ctx.fillStyle=p.col;ctx.fill();
    });
    ctx.globalAlpha=1;requestAnimationFrame(draw);
  })();
})();

/* Jump to section */
function jumpTo(id) {
  if(!id) return;
  const el = document.getElementById(id);
  if(el) el.scrollIntoView({behavior:'smooth',block:'start'});
  setTimeout(()=>{ document.getElementById('catSelect').value=''; }, 900);
}

/* Active pill on scroll */
(function(){
  const sections = Array.from(document.querySelectorAll('.cat-section'));
  const pills    = Array.from(document.querySelectorAll('.cat-pill'));
  const toolbar  = document.getElementById('toolbar');
  function onScroll(){
    const offset = 60 + (toolbar?.offsetHeight||52) + 24;
    let current='';
    sections.forEach(s=>{ if(window.scrollY+offset>=s.offsetTop) current=s.id; });
    pills.forEach(p=>p.classList.toggle('active',p.dataset.id===current));
  }
  window.addEventListener('scroll',onScroll,{passive:true});
  onScroll();
})();
</script>

</body>
</html>
