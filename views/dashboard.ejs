<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Coinfinex — Profile</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    :root{
      --bg:#03040a; --sidebar:#070910;
      --card:rgba(255,255,255,0.04); --card-hover:rgba(255,255,255,0.07);
      --border:rgba(255,255,255,0.08); --border-neon:rgba(0,245,196,0.25);
      --neon:#00f5c4; --neon2:#7b61ff; --neon3:#ff6b6b; --yellow:#ffd166;
      --text:#f0f0f0; --muted:rgba(240,240,240,0.45);
      --sidebar-w:240px;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;display:flex;overflow-x:hidden;cursor:none;}

    /* ── Cursor ── */
    #cur{position:fixed;width:10px;height:10px;border-radius:50%;background:var(--neon);pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:difference;transition:width .15s,height .15s;}
    #cur-ring{position:fixed;width:34px;height:34px;border-radius:50%;border:1.5px solid var(--neon);pointer-events:none;z-index:9998;transform:translate(-50%,-50%);opacity:.45;transition:width .2s,height .2s,opacity .2s;}

    /* ── Aurora ── */
    .aurora{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;}
    .ab{position:absolute;border-radius:50%;filter:blur(100px);opacity:.1;animation:dr 18s ease-in-out infinite alternate;}
    .ab:nth-child(1){width:700px;height:500px;background:var(--neon2);top:-100px;right:-100px;}
    .ab:nth-child(2){width:500px;height:400px;background:var(--neon);bottom:-100px;left:200px;animation-delay:-8s;}
    .ab:nth-child(3){width:400px;height:400px;background:var(--neon3);top:40%;left:50%;animation-delay:-4s;opacity:.06;}
    @keyframes dr{0%{transform:translate(0,0) scale(1)}100%{transform:translate(60px,40px) scale(1.05)}}

    /* ── Grid lines ── */
    .grid-lines{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(0,245,196,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,196,0.02) 1px,transparent 1px);background-size:80px 80px;animation:gridMove 30s linear infinite;}
    @keyframes gridMove{0%{background-position:0 0}100%{background-position:80px 80px}}

    /* ── Sidebar ── */
    .sidebar{position:fixed;left:0;top:0;bottom:0;width:var(--sidebar-w);background:var(--sidebar);border-right:1px solid var(--border);z-index:50;display:flex;flex-direction:column;animation:slideLeft .5s ease both;}
    @keyframes slideLeft{from{transform:translateX(-30px);opacity:0}to{transform:translateX(0);opacity:1}}

    .sb-logo{padding:28px 24px 24px;font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;background:linear-gradient(135deg,var(--neon),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;border-bottom:1px solid var(--border);text-decoration:none;display:block;letter-spacing:-.5px;}
    .sb-section-label{padding:20px 24px 8px;font-size:.67rem;letter-spacing:2px;text-transform:uppercase;color:rgba(240,240,240,0.2);}
    .sb-nav{list-style:none;padding:0 12px;}
    .sb-nav li{margin-bottom:2px;}
    .sb-nav a{display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:10px;color:var(--muted);text-decoration:none;font-size:.88rem;transition:all .2s;position:relative;}
    .sb-nav a .icon{font-size:1rem;width:22px;text-align:center;}
    .sb-nav a:hover{color:var(--text);background:var(--card);}
    .sb-nav a.active{color:var(--neon);background:rgba(0,245,196,0.08);}
    .sb-nav a.active::before{content:'';position:absolute;left:-12px;top:50%;transform:translateY(-50%);width:3px;height:20px;border-radius:2px;background:var(--neon);box-shadow:0 0 8px var(--neon);}
    .sb-badge{margin-left:auto;padding:2px 8px;border-radius:100px;background:rgba(255,107,107,0.15);color:var(--neon3);font-size:.7rem;font-weight:600;}

    .sb-bottom{margin-top:auto;padding:20px 24px;border-top:1px solid var(--border);}
    .user-mini{display:flex;align-items:center;gap:12px;}
    .user-av{width:36px;height:36px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;color:#03040a;}
    .user-mini-name{font-size:.85rem;font-weight:600;}
    .user-mini-role{font-size:.72rem;color:var(--muted);}
    .sb-logout{margin-top:12px;width:100%;padding:9px;background:rgba(255,107,107,0.08);border:1px solid rgba(255,107,107,0.15);border-radius:8px;color:var(--neon3);font-family:'DM Sans',sans-serif;font-size:.82rem;cursor:none;transition:all .2s;}
    .sb-logout:hover{background:rgba(255,107,107,0.18);border-color:rgba(255,107,107,0.3);}

    /* ── Main ── */
    .main{margin-left:var(--sidebar-w);flex:1;position:relative;z-index:1;min-height:100vh;}

    /* ── Live bar ── */
    .live-bar{background:rgba(0,245,196,0.04);border-bottom:1px solid rgba(0,245,196,0.08);padding:7px 36px;display:flex;align-items:center;gap:10px;font-size:.75rem;color:var(--muted);}
    .live-dot{width:6px;height:6px;border-radius:50%;background:var(--neon);animation:livePulse 1.5s infinite;flex-shrink:0;}
    @keyframes livePulse{0%,100%{box-shadow:0 0 0 0 rgba(0,245,196,.5)}50%{box-shadow:0 0 0 5px rgba(0,245,196,0)}}
    .live-text{color:var(--neon);font-weight:600;}

    /* ── Topbar ── */
    .topbar{position:sticky;top:0;z-index:40;display:flex;align-items:center;justify-content:space-between;padding:18px 36px;background:rgba(3,4,10,0.85);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
    .tb-left h1{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:700;}
    .tb-left p{color:var(--muted);font-size:.82rem;margin-top:2px;}
    .tb-right{display:flex;align-items:center;gap:12px;}
    .tb-icon-btn{width:36px;height:36px;border-radius:9px;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1rem;cursor:none;transition:all .2s;position:relative;}
    .tb-icon-btn:hover{border-color:var(--border-neon);}
    .notif-dot{position:absolute;top:7px;right:7px;width:7px;height:7px;border-radius:50%;background:var(--neon3);border:1.5px solid var(--bg);}
    .tb-user{width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-size:.8rem;font-weight:700;color:#03040a;cursor:none;box-shadow:0 0 14px rgba(0,245,196,0.25);}

    /* ── Page ── */
    .page{padding:36px 36px 60px;display:flex;flex-direction:column;gap:0;position:relative;}
    .page-heading{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;color:var(--muted);letter-spacing:.05em;text-transform:uppercase;margin-bottom:32px;animation:fadeUp .5s ease both;}

    /* ── Profile wrap ── */
    .profile-wrap{display:flex;justify-content:center;animation:fadeUp .5s .1s ease both;opacity:0;}

    /* ── Profile card ── */
    .profile-card{width:100%;max-width:500px;background:linear-gradient(160deg,rgba(13,18,36,0.95),rgba(7,9,16,0.95));border:1px solid var(--border);border-radius:24px;overflow:hidden;position:relative;}

    /* card shimmer border */
    .profile-card::before{content:'';position:absolute;inset:0;border-radius:24px;background:linear-gradient(135deg,rgba(0,245,196,0.07),transparent 50%,rgba(123,97,255,0.07));pointer-events:none;z-index:0;}

    /* ── Profile top ── */
    .profile-top{display:flex;flex-direction:column;align-items:center;padding:44px 32px 32px;border-bottom:1px solid rgba(255,255,255,0.05);position:relative;overflow:hidden;}

    /* glow ring behind avatar */
    .profile-top::before{content:'';position:absolute;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(0,245,196,0.12),transparent 70%);top:0;left:50%;transform:translateX(-50%);pointer-events:none;}

    .profile-avatar-wrap{position:relative;margin-bottom:20px;}
    .profile-avatar{
      width:88px;height:88px;border-radius:50%;
      background:linear-gradient(135deg,var(--neon),var(--neon2));
      display:flex;align-items:center;justify-content:center;
      font-family:'Syne',sans-serif;font-size:2.2rem;font-weight:800;color:#03040a;
      position:relative;z-index:1;
      animation:avatarPop .6s .3s ease both;opacity:0;
      box-shadow:0 0 0 4px rgba(0,245,196,0.12), 0 0 40px rgba(0,245,196,0.18);
    }
    @keyframes avatarPop{from{transform:scale(0.6);opacity:0}to{transform:scale(1);opacity:1}}

    /* spinning ring around avatar */
    .avatar-ring{
      position:absolute;inset:-6px;border-radius:50%;
      border:1.5px solid transparent;
      border-top-color:var(--neon);
      border-right-color:rgba(0,245,196,0.3);
      animation:spinRing 3s linear infinite;
      z-index:2;
    }
    .avatar-ring2{
      position:absolute;inset:-12px;border-radius:50%;
      border:1px solid transparent;
      border-bottom-color:var(--neon2);
      border-left-color:rgba(123,97,255,0.3);
      animation:spinRing 5s linear infinite reverse;
      z-index:2;
    }
    @keyframes spinRing{to{transform:rotate(360deg)}}

    /* online badge */
    .online-badge{
      position:absolute;bottom:2px;right:2px;z-index:3;
      width:16px;height:16px;border-radius:50%;
      background:var(--neon);border:2.5px solid #070910;
      box-shadow:0 0 8px var(--neon);
      animation:livePulse 2s infinite;
    }

    .profile-name{font-family:'Syne',sans-serif;font-size:1.35rem;font-weight:800;margin-bottom:5px;animation:fadeUp .5s .45s ease both;opacity:0;}
    .profile-since{font-size:.8rem;color:var(--muted);animation:fadeUp .5s .5s ease both;opacity:0;}

    /* stat chips under name */
    .profile-stats{display:flex;gap:12px;margin-top:20px;flex-wrap:wrap;justify-content:center;animation:fadeUp .5s .55s ease both;opacity:0;}
    .pstat{
      display:flex;flex-direction:column;align-items:center;
      padding:10px 18px;background:rgba(255,255,255,0.04);
      border:1px solid var(--border);border-radius:12px;min-width:80px;
      transition:border-color .2s,background .2s;
    }
    .pstat:hover{border-color:var(--border-neon);background:rgba(0,245,196,0.04);}
    .pstat-val{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;color:var(--neon);line-height:1;}
    .pstat-lbl{font-size:.65rem;color:var(--muted);letter-spacing:.05em;text-transform:uppercase;margin-top:4px;}

    /* ── Info rows ── */
    .profile-body{padding:6px 0;}
    .info-row{
      display:flex;align-items:center;gap:16px;
      padding:16px 28px;
      border-bottom:1px solid rgba(255,255,255,0.04);
      transition:background .2s,padding-left .2s;
      position:relative;
      animation:fadeUp .4s ease both;opacity:0;
    }
    .info-row:last-child{border-bottom:none;}
    .info-row:hover{background:rgba(255,255,255,0.025);padding-left:32px;}
    .info-row::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--neon);transform:scaleY(0);transition:transform .2s;border-radius:2px;}
    .info-row:hover::before{transform:scaleY(1);}
    .info-icon{width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.05);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.95rem;transition:border-color .2s,background .2s;}
    .info-row:hover .info-icon{border-color:rgba(0,245,196,0.2);background:rgba(0,245,196,0.06);}
    .info-label{font-size:.68rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:3px;}
    .info-value{font-size:.9rem;font-weight:500;color:var(--text);}
    .info-value.danger{color:var(--neon3);}
    .info-value.success{color:var(--neon);}

    /* ── Activity mini ── */
    .activity-strip{margin:0 24px 0;border-bottom:1px solid rgba(255,255,255,0.04);padding-bottom:0;}
    .activity-label{padding:14px 4px 10px;font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);}
    .act-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.03);}
    .act-item:last-child{border-bottom:none;}
    .act-dot-wrap{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
    .act-txt{font-size:.8rem;color:var(--muted);flex:1;}
    .act-txt strong{color:var(--text);}
    .act-time{font-size:.7rem;color:rgba(240,240,240,0.25);white-space:nowrap;}

    /* ── UID bar ── */
    .uid-bar{
      margin:20px 24px 24px;
      padding:13px 18px;
      background:rgba(0,0,0,0.4);
      border:1px solid var(--border);
      border-radius:12px;
      font-family:'DM Mono','Courier New',monospace;
      font-size:.72rem;color:var(--muted);
      display:flex;align-items:center;justify-content:space-between;gap:10px;
      animation:fadeUp .5s .8s ease both;opacity:0;
      transition:border-color .2s;
    }
    .uid-bar:hover{border-color:rgba(0,245,196,0.15);}
    .uid-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:rgba(240,240,240,.25);margin-bottom:3px;}
    .uid-val{color:var(--text);}
    .uid-copy{background:rgba(0,245,196,0.08);border:1px solid rgba(0,245,196,0.2);border-radius:7px;padding:5px 12px;font-size:.7rem;color:var(--neon);cursor:none;transition:all .2s;white-space:nowrap;font-family:'DM Sans',sans-serif;}
    .uid-copy:hover{background:rgba(0,245,196,0.16);border-color:rgba(0,245,196,0.4);}

    /* ── Footer ── */
    .page-footer{margin-top:44px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;font-size:.74rem;color:rgba(240,240,240,0.18);animation:fadeUp .5s .9s ease both;opacity:0;}
    .footer-links{display:flex;gap:18px;}
    .footer-links a{color:rgba(240,240,240,0.25);text-decoration:none;transition:color .2s;}
    .footer-links a:hover{color:var(--neon);}

    /* ── Animations ── */
    @keyframes fadeUp{from{transform:translateY(18px);opacity:0}to{transform:translateY(0);opacity:1}}

    /* ── Stagger info rows ── */
    .info-row:nth-child(1){animation-delay:.35s}
    .info-row:nth-child(2){animation-delay:.42s}
    .info-row:nth-child(3){animation-delay:.49s}
    .info-row:nth-child(4){animation-delay:.56s}

    /* ── Floating particles ── */
    .particle{position:fixed;border-radius:50%;pointer-events:none;z-index:0;animation:floatParticle linear infinite;opacity:0;}
    @keyframes floatParticle{0%{transform:translateY(100vh) scale(0);opacity:0}10%{opacity:1}90%{opacity:.6}100%{transform:translateY(-100px) scale(1.2);opacity:0}}

    @media(max-width:768px){
      .sidebar{transform:translateX(-100%);}
      .main{margin-left:0;}
      .page{padding:20px 16px 48px;}
      .live-bar{padding:7px 16px;}
      .topbar{padding:14px 20px;}
    }
  </style>
</head>
<body>

<%
  const u = typeof user !== 'undefined' && user
    ? user
    : { name:'Unknown', role:'Unknown', initials:'U' };
%>

<div id="cur"></div>
<div id="cur-ring"></div>
<div class="grid-lines"></div>
<div class="aurora">
  <div class="ab"></div><div class="ab"></div><div class="ab"></div>
</div>
<div id="particles"></div>

<!-- ── Sidebar ── -->
<aside class="sidebar">
  <a href="/" class="sb-logo">Coinfinex</a>

  <div class="sb-section-label">Main</div>
  <ul class="sb-nav">
    <li><a href="/dashboard/<%= u.name %>"><span class="icon">⚡</span>Dashboard</a></li>
    <li><a href="/categories"><span class="icon">📊</span>Categories</a></li>
    <li><a href="/virtual-trading"><span class="icon">📦</span>Virtual Trading</a></li>
    <li><a href="/news"><span class="icon">📰</span>News</a></li>
  </ul>

  <div class="sb-bottom">
    <div class="user-mini">
      <div class="user-av"><%= u.initials %></div>
      <div>
        <div class="user-mini-name"><%= u.name %></div>
        <div class="user-mini-role"><%= u.role %></div>
      </div>
    </div>
    <a href="/logout"><button class="sb-logout">↩ Log Out</button></a>
  </div>
</aside>

<!-- ── Main ── -->
<div class="main">

  <!-- Live bar -->
  <div class="live-bar">
    <div class="live-dot"></div>
    <span class="live-text">Live</span>
    <span id="live-msg">Market data active · All systems operational</span>
  </div>

  <!-- Topbar -->
  <div class="topbar">
    <div class="tb-left">
      <h1>Profile</h1>
      <p>Your account information &amp; stats</p>
    </div>
    <div class="tb-right">
      <div class="tb-icon-btn">🔔<div class="notif-dot"></div></div>
      <div class="tb-icon-btn">🌐</div>
      <div class="tb-user"><%= u.initials %></div>
    </div>
  </div>

  <!-- Page -->
  <div class="page">
    <div class="page-heading">Profile</div>

    <div class="profile-wrap">
      <div class="profile-card">

        <!-- Top: avatar + name + stats -->
        <div class="profile-top">
          <div class="profile-avatar-wrap">
            <div class="avatar-ring2"></div>
            <div class="avatar-ring"></div>
            <div class="profile-avatar"><%= u.initials %></div>
            <div class="online-badge"></div>
          </div>
          <div class="profile-name"><%= u.name %></div>
          <div class="profile-since">Member since <%= new Date().toLocaleDateString('en-GB') %></div>
          <div class="profile-stats">
            <div class="pstat">
              <div class="pstat-val" data-count="24">0</div>
              <div class="pstat-lbl">Trades</div>
            </div>
            <div class="pstat">
              <div class="pstat-val" data-count="7">0</div>
              <div class="pstat-lbl">Holdings</div>
            </div>
            <div class="pstat">
              <div class="pstat-val" data-count="42">0</div>
              <div class="pstat-lbl">Days Active</div>
            </div>
          </div>
        </div>

        <!-- Info rows -->
        <div class="profile-body">
          <div class="info-row">
            <div class="info-icon">👤</div>
            <div>
              <div class="info-label">Username</div>
              <div class="info-value"><%= u.name %></div>
            </div>
          </div>
          <div class="info-row">
            <div class="info-icon">🛡️</div>
            <div>
              <div class="info-label">Role</div>
              <div class="info-value"><%= u.role %></div>
            </div>
          </div>
          <div class="info-row">
            <div class="info-icon">✅</div>
            <div>
              <div class="info-label">Account Status</div>
              <div class="info-value success">Active</div>
            </div>
          </div>
          <div class="info-row">
            <div class="info-icon">🕒</div>
            <div>
              <div class="info-label">Last Login</div>
              <div class="info-value"><%= new Date().toLocaleString('en-GB') %></div>
            </div>
          </div>
        </div>

        <!-- Recent activity mini -->
        <div style="padding:0 24px;">
          <div class="activity-label">Recent Activity</div>
          <div class="act-item" style="animation:fadeUp .4s .6s ease both;opacity:0">
            <div class="act-dot-wrap" style="background:#00f5c4;box-shadow:0 0 5px #00f5c4"></div>
            <div class="act-txt">Logged in from <strong>new device</strong></div>
            <div class="act-time">Just now</div>
          </div>
          <div class="act-item" style="animation:fadeUp .4s .65s ease both;opacity:0">
            <div class="act-dot-wrap" style="background:#7b61ff;box-shadow:0 0 5px #7b61ff"></div>
            <div class="act-txt">Viewed <strong>Virtual Trading</strong></div>
            <div class="act-time">5m ago</div>
          </div>
          <div class="act-item" style="animation:fadeUp .4s .7s ease both;opacity:0">
            <div class="act-dot-wrap" style="background:#ffd166;box-shadow:0 0 5px #ffd166"></div>
            <div class="act-txt">Browsed <strong>Categories</strong></div>
            <div class="act-time">12m ago</div>
          </div>
        </div>

        <!-- UID bar -->
        <div class="uid-bar">
          <div>
            <div class="uid-label">User ID</div>
            <div class="uid-val" id="uidVal"><%= Buffer.from(u.name).toString('base64').slice(0,28) %>...</div>
          </div>
          <button class="uid-copy" onclick="copyUID()">Copy</button>
        </div>

      </div>
    </div>

    <!-- Footer -->
    <div class="page-footer">
      <span>© 2026 Coinfinex · Real-time market data</span>
      <div class="footer-links">
        <a href="#">About</a>
        <a href="#">API</a>
        <a href="#">Docs</a>
        <a href="#">Privacy</a>
      </div>
    </div>

  </div>
</div>

<script>
/* ── Cursor ── */
const cur=document.getElementById('cur'),ring=document.getElementById('cur-ring');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;cur.style.left=mx+'px';cur.style.top=my+'px';});
(function loop(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loop);})();
document.querySelectorAll('a,button,.tb-icon-btn,.tb-user,.profile-avatar,.pstat,.info-row,.uid-copy,.sb-logout').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.style.width='18px';cur.style.height='18px';ring.style.width='48px';ring.style.height='48px';ring.style.opacity='.65';});
  el.addEventListener('mouseleave',()=>{cur.style.width='10px';cur.style.height='10px';ring.style.width='34px';ring.style.height='34px';ring.style.opacity='.45';});
});

/* ── Floating particles ── */
(()=>{
  const colors=['#00f5c4','#7b61ff','#ff6b6b','#ffd166'];
  const wrap=document.getElementById('particles');
  for(let i=0;i<18;i++){
    const p=document.createElement('div');
    p.className='particle';
    const size=Math.random()*3+1;
    p.style.cssText=`
      width:${size}px;height:${size}px;
      left:${Math.random()*100}vw;
      background:${colors[Math.floor(Math.random()*colors.length)]};
      animation-duration:${Math.random()*12+8}s;
      animation-delay:${Math.random()*8}s;
      box-shadow:0 0 ${size*3}px currentColor;
    `;
    wrap.appendChild(p);
  }
})();

/* ── Counter animation ── */
document.querySelectorAll('[data-count]').forEach(el=>{
  const target=+el.getAttribute('data-count'),dur=1200;
  let start=null;
  const ease=t=>t<.5?2*t*t:-1+(4-2*t)*t;
  const step=t=>{
    if(!start)start=t;
    const p=Math.min((t-start)/dur,1);
    el.textContent=Math.round(ease(p)*target);
    if(p<1)requestAnimationFrame(step);
  };
  setTimeout(()=>requestAnimationFrame(step),500);
});

/* ── Live bar messages ── */
const msgs=[
  'Market data active · All systems operational',
  'Alpha Vantage API connected',
  'Virtual portfolio is being tracked',
  'Real-time updates enabled',
];
let mi=0;
setInterval(()=>{
  mi=(mi+1)%msgs.length;
  const el=document.getElementById('live-msg');
  el.style.opacity='0';
  setTimeout(()=>{el.textContent=msgs[mi];el.style.opacity='1';el.style.transition='opacity .35s';},320);
},4000);

/* ── Copy UID ── */
function copyUID(){
  const val=document.getElementById('uidVal').textContent;
  navigator.clipboard.writeText(val).then(()=>{
    const btn=document.querySelector('.uid-copy');
    const orig=btn.textContent;
    btn.textContent='Copied ✓';
    btn.style.color='var(--neon)';
    btn.style.borderColor='rgba(0,245,196,.5)';
    setTimeout(()=>{btn.textContent=orig;btn.style.color='';btn.style.borderColor='';},2000);
  });
}
</script>
