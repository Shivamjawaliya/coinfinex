  /* ── Cursor ─────────────────────────────────── */
  (() => {
    const dot  = document.getElementById('cursor');
    const ring = document.getElementById('cursor-ring');
    let mx=0,my=0,rx=0,ry=0;
    document.addEventListener('mousemove', e => {
      mx=e.clientX; my=e.clientY;
      dot.style.left=mx+'px'; dot.style.top=my+'px';
    });
    (function loopRing(){
      rx+=(mx-rx)*.12; ry+=(my-ry)*.12;
      ring.style.left=rx+'px'; ring.style.top=ry+'px';
      requestAnimationFrame(loopRing);
    })();
    const hoverEls = () => document.querySelectorAll('a,button,.stock-card,.nav-pill,.filter-btn,.page-btn,.sort-dir,.sort-select,.tb-user,.nav-logout');
    function attachHover(){
      hoverEls().forEach(el=>{
        el.addEventListener('mouseenter',()=>{dot.style.width='20px';dot.style.height='20px';ring.style.width='52px';ring.style.height='52px';ring.style.opacity='.75';});
        el.addEventListener('mouseleave',()=>{dot.style.width='10px';dot.style.height='10px';ring.style.width='36px';ring.style.height='36px';ring.style.opacity='.5';});
      });
    }
    attachHover();
    window._reattachCursor = attachHover;
  })();

  /* ── Particles ──────────────────────────────── */
  (() => {
    const canvas=document.getElementById('particle-canvas');
    const ctx=canvas.getContext('2d');
    let W,H;
    function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;}
    resize(); window.addEventListener('resize',resize);
    const PAL=['#00f5c4','#7b61ff','#ff6b6b','rgba(240,240,240,0.5)'];
    const particles=Array.from({length:100},()=>({
      x:Math.random()*window.innerWidth, y:Math.random()*window.innerHeight,
      r:Math.random()*1.4+0.3,
      vx:(Math.random()-.5)*.35, vy:(Math.random()-.5)*.35,
      a:Math.random()*.35+.07,
      col:PAL[Math.floor(Math.random()*PAL.length)]
    }));
    let pmx=-9999,pmy=-9999;
    document.addEventListener('mousemove',e=>{pmx=e.clientX;pmy=e.clientY;});
    (function drawLoop(){
      ctx.clearRect(0,0,W,H);
      for(let i=0;i<particles.length;i++)for(let j=i+1;j<particles.length;j++){
        const d=Math.hypot(particles[i].x-particles[j].x,particles[i].y-particles[j].y);
        if(d<100){ctx.beginPath();ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);ctx.strokeStyle='#00f5c4';ctx.globalAlpha=(1-d/100)*.055;ctx.lineWidth=.6;ctx.stroke();}
      }
      particles.forEach(p=>{
        const dx=p.x-pmx,dy=p.y-pmy,d=Math.hypot(dx,dy);
        if(d<110){const f=((110-d)/110)*.5;p.vx+=(dx/d)*f;p.vy+=(dy/d)*f;}
        p.vx*=.982;p.vy*=.982;p.x+=p.vx;p.y+=p.vy;
        if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;
        ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
        ctx.globalAlpha=p.a;ctx.fillStyle=p.col;ctx.fill();
      });
      ctx.globalAlpha=1;requestAnimationFrame(drawLoop);
    })();
  })();

