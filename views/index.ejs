<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Explore — Coinfinex</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg:#03040a;
      --neon:#00f5c4;
      --neon2:#7b61ff;
      --neon3:#ff6b6b;
      --text:#f0f0f0;
      --muted:rgba(240,240,240,0.5);
      --surface:rgba(255,255,255,0.03);
      --surface2:rgba(255,255,255,0.055);
      --border:rgba(255,255,255,0.07);
      --border-hover:rgba(0,245,196,0.22);
      --up:#00e676;
      --dn:#ff6b6b;
    }

    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; overflow-x:hidden; }

    body {
      background:var(--bg);
      color:var(--text);
      font-family:'DM Sans', sans-serif;
      overflow-x:hidden;
      cursor:none;
      min-height:100vh;
    }

    /* ── Custom cursor ─────────────────────────── */
    #cursor {
      position:fixed; width:10px; height:10px;
      border-radius:50%; background:var(--neon);
      pointer-events:none; z-index:99999;
      transform:translate(-50%,-50%);
      transition:width .15s, height .15s, background .2s;
      mix-blend-mode:difference;
    }
    #cursor-ring {
      position:fixed; width:36px; height:36px;
      border-radius:50%; border:1.5px solid var(--neon);
      pointer-events:none; z-index:99998;
      transform:translate(-50%,-50%);
      opacity:.5; transition:width .2s, height .2s;
    }

    /* ── Background effects ────────────────────── */
    #particle-canvas { position:fixed; inset:0; z-index:0; pointer-events:none; }

    .grid-lines {
      position:fixed; inset:0; z-index:0; pointer-events:none;
      background-image:
        linear-gradient(rgba(0,245,196,0.028) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,245,196,0.028) 1px, transparent 1px);
      background-size:80px 80px;
      animation:gridMove 25s linear infinite;
    }
    @keyframes gridMove {
      0%   { background-position:0 0; }
      100% { background-position:80px 80px; }
    }

    .aurora { position:fixed; inset:0; z-index:0; overflow:hidden; pointer-events:none; }
    .blob {
      position:absolute; border-radius:50%;
      filter:blur(100px); opacity:0.15;
      animation:float 15s infinite alternate;
    }
    .blob:nth-child(1){ width:600px;height:600px;background:var(--neon2);top:-100px;left:-100px;animation-duration:15s; }
    .blob:nth-child(2){ width:500px;height:500px;background:var(--neon);bottom:-100px;right:-100px;animation-duration:18s;animation-delay:-5s; }
    .blob:nth-child(3){ width:400px;height:350px;background:var(--neon3);top:50%;left:30%;animation-duration:12s;animation-delay:-9s; }
    @keyframes float {
      0%   { transform:translate(0,0) scale(1); }
      50%  { transform:translate(80px,60px) scale(1.08); }
      100% { transform:translate(-40px,40px) scale(0.95); }
    }

    /* ── Nav ───────────────────────────────────── */
    nav {
      position:fixed; top:0; left:0; right:0; z-index:1000;
      display:flex; justify-content:space-between; align-items:center;
      padding:0 2%;
      backdrop-filter:blur(20px);
      background:rgba(0,0,0,0.5);
      border-bottom:1px solid var(--border);
      height:60px;
      animation:navIn .6s ease both;
    }
    @keyframes navIn { from{opacity:0;transform:translateY(-20px)} to{opacity:1;transform:translateY(0)} }

    .nav-left {
      display:flex; align-items:center; gap:0;
    }

    .nav-brand {
      display:flex; align-items:center; gap:10px;
      padding:0 20px;
      border-right:1px solid var(--border);
      height:60px;
      text-decoration:none;
    }
    .nav-brand-icon {
      width:32px; height:32px; border-radius:8px;
      background:linear-gradient(135deg,var(--neon),var(--neon2));
      display:flex; align-items:center; justify-content:center;
      font-family:'Syne'; font-size:0.8rem; font-weight:800; color:#03040a;
    }
    .nav-brand-text {
      font-family:'Syne'; font-size:1rem; font-weight:800;
      color:var(--text);
    }

    /* ── Nav tabs ──────────────────────────────── */
    .nav-tabs {
      display:flex; align-items:center; height:60px;
    }
    .nav-tab {
      display:flex; align-items:center; height:100%;
      padding:0 28px; text-decoration:none;
      font-size:0.9rem; color:var(--muted);
      border-bottom:2px solid transparent;
      transition:color .25s, border-color .25s;
      white-space:nowrap;
    }
    .nav-tab:hover { color:var(--text); }
    .nav-tab.active { color:var(--neon); border-bottom-color:var(--neon); }

    /* ── Nav right ─────────────────────────────── */
    .nav-right {
      display:flex; align-items:center; gap:10px;
    }

    .nav-pill {
      display:flex; align-items:center; gap:7px;
      background:rgba(255,255,255,0.05);
      border:1px solid var(--border);
      border-radius:8px; padding:7px 14px;
      font-size:0.82rem; color:var(--muted);
      cursor:none; transition:all .25s;
    }
    .nav-pill:hover { border-color:var(--neon); color:var(--neon); }
    .nav-pill.active { background:rgba(0,245,196,0.08); border-color:rgba(0,245,196,0.35); color:var(--neon); }
    .nav-pill svg { width:14px; height:14px; }

    .nav-divider { width:1px; height:28px; background:var(--border); }

    .nav-currency {
      display:flex; align-items:center; gap:6px;
      background:rgba(255,255,255,0.05);
      border:1px solid var(--border);
      border-radius:8px; padding:7px 14px;
      font-size:0.82rem; color:var(--text);
      cursor:none; transition:all .25s;
    }
    .nav-currency:hover { border-color:var(--neon2); }
    .nav-currency select {
      background:transparent; border:none; color:var(--text);
      font-family:'DM Sans'; font-size:0.82rem; outline:none; cursor:none;
    }
    .nav-currency select option { background:#0d0f1a; }

    .nav-settings {
      width:36px; height:36px; border-radius:8px;
      background:rgba(255,255,255,0.05);
      border:1px solid var(--border);
      display:flex; align-items:center; justify-content:center;
      cursor:none; transition:all .25s; color:var(--muted);
    }
    .nav-settings:hover { border-color:var(--neon); color:var(--neon); }

    .tb-user {
      display:flex; align-items:center; gap:10px;
      padding:6px 14px 6px 8px;
      background:rgba(255,255,255,0.05);
      border:1px solid var(--border);
      border-radius:8px;
      cursor:none; transition:all .25s;
    }
    .tb-user:hover { border-color:var(--neon); }
    .tb-avatar {
      width:28px; height:28px; border-radius:50%;
      background:linear-gradient(135deg,var(--neon),var(--neon2));
      display:flex; align-items:center; justify-content:center;
      font-size:.72rem; font-weight:800; color:#03040a;
      flex-shrink:0;
    }
    .tb-name { font-size:0.82rem; color:var(--text); }

    .nav-logout {
      width:36px; height:36px; border-radius:8px;
      background:rgba(255,107,107,0.08);
      border:1px solid rgba(255,107,107,0.2);
      display:flex; align-items:center; justify-content:center;
      cursor:none; transition:all .25s; color:var(--neon3);
      text-decoration:none;
    }
    .nav-logout:hover { background:rgba(255,107,107,0.15); border-color:var(--neon3); }

    /* ── Page layout ───────────────────────────── */
    .page {
      position:relative; z-index:1;
      padding:80px 0 60px;
      min-height:100vh;
    }

    .container {
      max-width:1400px;
      margin:0 auto;
      padding:0 32px;
    }

    /* ── Explore header ────────────────────────── */
    .explore-header {
      padding:32px 32px 0;
      max-width:1400px; margin:0 auto;
      animation:fadeUp .7s ease both;
    }
    .explore-title {
      font-family:'Syne'; font-size:1.8rem; font-weight:800;
      margin-bottom:28px;
    }

    /* ── Filters bar ───────────────────────────── */
    .filters-bar {
      background:rgba(255,255,255,0.03);
      border:1px solid var(--border);
      border-radius:16px;
      padding:16px 20px;
      display:flex; align-items:center; gap:12px;
      flex-wrap:wrap;
      animation:fadeUp .7s .1s ease both; opacity:0;
    }

    .search-wrap {
      flex:1; min-width:240px;
      position:relative;
    }
    .search-wrap svg {
      position:absolute; left:14px; top:50%; transform:translateY(-50%);
      color:var(--muted); width:16px; height:16px;
    }
    .search-input {
      width:100%;
      background:rgba(0,0,0,0.4);
      border:1px solid var(--border);
      border-radius:10px;
      padding:10px 14px 10px 40px;
      color:var(--text);
      font-family:'DM Sans'; font-size:0.9rem;
      outline:none; transition:all .25s;
    }
    .search-input::placeholder { color:var(--muted); }
    .search-input:focus { border-color:var(--neon); box-shadow:0 0 20px rgba(0,245,196,0.1); }

    .filter-sep { width:1px; height:28px; background:var(--border); flex-shrink:0; }

    .filter-btn {
      padding:9px 18px; border-radius:8px;
      font-family:'DM Sans'; font-size:0.85rem;
      border:1px solid var(--border);
      background:transparent; color:var(--muted);
      cursor:none; transition:all .25s; white-space:nowrap;
    }
    .filter-btn:hover { border-color:rgba(0,245,196,0.3); color:var(--text); }
    .filter-btn.active {
      background:rgba(0,245,196,0.1);
      border-color:rgba(0,245,196,0.45);
      color:var(--neon);
    }

    .sort-wrap {
      display:flex; align-items:center; gap:8px;
      margin-left:auto;
    }
    .sort-select {
      background:rgba(0,0,0,0.4);
      border:1px solid var(--border);
      border-radius:8px; padding:9px 14px;
      color:var(--text); font-family:'DM Sans'; font-size:0.85rem;
      outline:none; cursor:none; transition:all .25s;
    }
    .sort-select:hover { border-color:rgba(0,245,196,0.3); }
    .sort-select option { background:#0d0f1a; }

    .sort-dir {
      padding:9px 14px; border-radius:8px;
      font-family:'DM Sans'; font-size:0.82rem;
      border:1px solid rgba(0,245,196,0.3);
      background:rgba(0,245,196,0.06); color:var(--neon);
      cursor:none; transition:all .25s; white-space:nowrap;
    }
    .sort-dir:hover { background:rgba(0,245,196,0.14); }

    /* ── Results meta bar ──────────────────────── */
    .results-meta {
      display:flex; align-items:center; justify-content:space-between;
      padding:18px 32px;
      max-width:1400px; margin:0 auto;
      font-size:0.82rem; color:var(--muted);
      animation:fadeUp .7s .2s ease both; opacity:0;
    }
    .results-meta strong { color:var(--text); }
    .pagination-info { display:flex; align-items:center; gap:16px; }
    .page-btn {
      padding:6px 16px; border-radius:7px;
      font-family:'DM Sans'; font-size:0.8rem;
      border:1px solid var(--border);
      background:transparent; color:var(--muted);
      cursor:none; transition:all .25s;
    }
    .page-btn:hover:not(:disabled) { border-color:var(--neon); color:var(--neon); }
    .page-btn:disabled { opacity:.35; }
    .page-btn.active { background:rgba(0,245,196,0.1); border-color:rgba(0,245,196,0.4); color:var(--neon); }

    /* ── Stock cards grid ──────────────────────── */
    .stocks-grid {
      display:grid;
      grid-template-columns:repeat(4, 1fr);
      gap:16px;
      padding:0 32px 32px;
      max-width:1400px; margin:0 auto;
    }

    .stock-card {
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:18px;
      padding:22px;
      cursor:none;
      position:relative;
      overflow:hidden;
      transition:transform .35s, border-color .35s, box-shadow .35s;
      animation:fadeUp .6s ease calc(var(--i,0) * 0.06s) both; opacity:0;
    }
    .stock-card::before {
      content:''; position:absolute; inset:0;
      background:radial-gradient(circle at 80% 10%, rgba(0,245,196,0.06), transparent 65%);
      opacity:0; transition:opacity .3s;
    }
    .stock-card:hover::before { opacity:1; }
    .stock-card:hover {
      transform:translateY(-5px);
      border-color:var(--border-hover);
      box-shadow:0 24px 64px rgba(0,0,0,0.5);
    }

    /* card accent bar */
    .stock-card::after {
      content:''; position:absolute;
      top:0; left:0; right:0; height:2px;
      background:linear-gradient(90deg, var(--card-accent, var(--neon)), transparent);
      opacity:0; transition:opacity .3s;
    }
    .stock-card:hover::after { opacity:1; }

    .card-head {
      display:flex; align-items:center; gap:12px;
      margin-bottom:18px;
    }
    .card-logo {
      width:40px; height:40px; border-radius:10px;
      background:linear-gradient(135deg, var(--logo-a, #00f5c4), var(--logo-b, #7b61ff));
      display:flex; align-items:center; justify-content:center;
      font-family:'Syne'; font-size:0.75rem; font-weight:800;
      color:#03040a; flex-shrink:0; letter-spacing:-.5px;
    }
    .card-name-wrap { flex:1; min-width:0; }
    .card-symbol {
      font-family:'Syne'; font-size:1rem; font-weight:800;
      color:var(--text); line-height:1.2;
    }
    .card-fullname {
      font-size:0.7rem; color:var(--muted);
      white-space:nowrap; overflow:hidden; text-overflow:ellipsis;
      margin-top:2px;
    }

    .card-row {
      display:flex; justify-content:space-between; align-items:center;
      padding:8px 0;
      border-bottom:1px solid var(--border);
    }
    .card-row:last-child { border-bottom:none; padding-bottom:0; }
    .card-row:first-of-type { padding-top:0; }
    .row-label {
      font-size:0.72rem; color:var(--muted); letter-spacing:.5px;
    }
    .row-value {
      font-size:0.88rem; font-weight:600; color:var(--text);
    }
    .row-value.up { color:var(--up); }
    .row-value.dn { color:var(--dn); }
    .row-value.price {
      font-family:'Syne'; font-size:1rem; font-weight:800; color:var(--neon);
    }

    /* ── Loader overlay ────────────────────────── */
    #loader {
      display:none; position:fixed; inset:0;
      background:rgba(3,4,10,0.88); z-index:2000;
      justify-content:center; align-items:center;
      flex-direction:column; gap:20px;
      backdrop-filter:blur(8px);
    }
    #loader.show { display:flex; }
    .loader-ring {
      width:56px; height:56px;
      border:2px solid var(--border);
      border-top-color:var(--neon);
      border-radius:50%;
      animation:spin .8s linear infinite;
    }
    @keyframes spin { to{transform:rotate(360deg)} }
    .loader-text {
      font-size:0.75rem; letter-spacing:3px;
      color:var(--neon); text-transform:uppercase;
    }

    /* ── Empty state ───────────────────────────── */
    .empty-state {
      grid-column:1/-1;
      text-align:center; padding:80px 20px;
      color:var(--muted);
    }
    .empty-state svg { width:48px; height:48px; margin-bottom:16px; opacity:.4; }
    .empty-state p { font-size:1rem; }

    /* ── Animations ────────────────────────────── */
    @keyframes fadeUp {
      from{ opacity:0; transform:translateY(22px); }
      to  { opacity:1; transform:translateY(0); }
    }

    /* ── Responsive ────────────────────────────── */
    @media(max-width:1200px){ .stocks-grid{ grid-template-columns:repeat(3,1fr); } }
    @media(max-width:900px){
      .stocks-grid{ grid-template-columns:repeat(2,1fr); }
      .nav-tabs .nav-tab:not(.active){ display:none; }
    }
    @media(max-width:600px){
      .stocks-grid{ grid-template-columns:1fr; }
      .filters-bar{ gap:8px; }
      .sort-wrap{ margin-left:0; }
    }
  </style>
</head>
<body>

  <div id="cursor"></div>
  <div id="cursor-ring"></div>
  <div class="grid-lines"></div>
  <div class="aurora">
    <div class="blob"></div><div class="blob"></div><div class="blob"></div>
  </div>
  <canvas id="particle-canvas"></canvas>

  <!-- ── Loader ─────────────────────────────── -->
  <div id="loader">
    <div class="loader-ring"></div>
    <div class="loader-text">Loading Markets...</div>
  </div>

  <!-- ── Navigation ─────────────────────────── -->
  <nav id="navbar">
    <div class="nav-left">
      <a href="/" class="nav-brand">
        <div class="nav-brand-icon">CF</div>
        <span class="nav-brand-text">Coinfinex</span>
      </a>
      <div class="nav-tabs">
        <a href="/explore" class="nav-tab active">Explore</a>
        <a href="/categories" class="nav-tab">Categories</a>
        <a href="/portfolio" class="nav-tab">Portfolio</a>
        <a href="/news" class="nav-tab">News</a>
        <a href="/virtual-trading" class="nav-tab">Virtual Trading</a>
      </div>
    </div>

    <div class="nav-right">
      <!-- Crypto toggle -->
      <button class="nav-pill" id="cryptoToggle" onclick="toggleMode('crypto')">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9 8h5a2 2 0 0 1 0 4H9v4h5"/><path d="M12 6v2m0 8v2"/></svg>
        Crypto
      </button>
      <button class="nav-pill active" id="stocksToggle" onclick="toggleMode('stocks')">
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
        Stocks
      </button>

      <div class="nav-divider"></div>

      <!-- Currency selector -->
      <div class="nav-currency">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        <select id="currencySelect" onchange="changeCurrency()">
          <option value="INR" selected>INR</option>
          <option value="USD">USD</option>
          <option value="EUR">EUR</option>
          <option value="GBP">GBP</option>
        </select>
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
      </div>

      <div class="nav-divider"></div>

      <button class="nav-settings" title="Settings">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </button>

      <% if (typeof user !== 'undefined' && user && (user.username || user.email)) { %>
        <a href="/dashboard/<%= encodeURIComponent(user.username || user.email) %>" class="tb-user">
          <div class="tb-avatar">
            <%= (user.username && user.username[0] ? user.username[0].toUpperCase() : (user.email && user.email[0] ? user.email[0].toUpperCase() : 'U')) %>
          </div>
          <span class="tb-name"><%= user.username || user.email %></span>
        </a>
        <a href="/logout" class="nav-logout" title="Logout">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </a>
      <% } else { %>
        <a href="/login" style="padding:8px 18px;border-radius:8px;border:1px solid rgba(255,255,255,0.2);color:var(--text);font-size:0.85rem;text-decoration:none;transition:all .25s;" onmouseenter="this.style.borderColor='var(--neon)';this.style.color='var(--neon)'" onmouseleave="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='var(--text)'">Login</a>
        <a href="/signup" style="padding:8px 18px;border-radius:8px;background:linear-gradient(135deg,var(--neon),var(--neon2));color:#000;font-size:0.85rem;font-weight:700;text-decoration:none;transition:transform .2s;" onmouseenter="this.style.transform='scale(1.05)'" onmouseleave="this.style.transform='scale(1)'">Sign Up</a>
      <% } %>
    </div>
  </nav>

  <!-- ── Page ───────────────────────────────── -->
  <div class="page">

    <div class="explore-header">
      <h1 class="explore-title">Most traded stocks</h1>

      <!-- Filters bar -->
      <div class="filters-bar">
        <div class="search-wrap">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
