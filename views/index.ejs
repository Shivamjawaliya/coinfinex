  function toLocalCurrency(usd) {
    return usd * CURRENCY_RATES[currentCurrency];
  }
  function formatPrice(usd) {
    const val = toLocalCurrency(usd);
    const sym = CURRENCY_SYMBOLS[currentCurrency];
    return sym + val.toLocaleString('en-IN', { maximumFractionDigits:2, minimumFractionDigits:2 });
  }
  function calcRange(usd, chg) {
    const factor = 1 + (chg/100);
    const open   = usd / factor;
    const low    = open * 0.995;
    const high   = usd * 1.005;
    return { open, low, high };
  }

  function getLogoGradient(idx) {
    const palettes = [
      ['#00f5c4','#7b61ff'],['#ff6b6b','#ffb800'],['#7b61ff','#00f5c4'],
      ['#ffb800','#ff6b6b'],['#00e676','#00f5c4'],['#ff6b6b','#7b61ff'],
    ];
    return palettes[idx % palettes.length];
  }

  function buildCard(stock, idx) {
    const { open, low, high } = calcRange(stock.priceUSD, stock.change);
    const isUp = stock.change >= 0;
    const chgClass = isUp ? 'up' : 'dn';
    const chgSign  = isUp ? '+' : '';
    const prevClose = stock.priceUSD / (1 + stock.change/100);

    const dayRangeStr = `${formatPrice(low)} – ${formatPrice(high)}`;

    return `
    <div class="stock-card" style="--i:${idx};--card-accent:${stock.logoA}"
         onclick="viewStock('${stock.symbol}')">
      <div class="card-head">
        <div class="card-logo" style="background:linear-gradient(135deg,${stock.logoA},${stock.logoB})">
          ${stock.initials}
        </div>
        <div class="card-name-wrap">
          <div class="card-symbol">${stock.symbol}</div>
          <div class="card-fullname">${stock.name.toUpperCase()}</div>
        </div>
      </div>
      <div class="card-row">
        <span class="row-label">Price</span>
        <span class="row-value price">${formatPrice(stock.priceUSD)}</span>
      </div>
      <div class="card-row">
        <span class="row-label">Change</span>
        <span class="row-value ${chgClass}">${chgSign}${stock.change.toFixed(2)}%</span>
      </div>
      <div class="card-row">
        <span class="row-label">Day Range</span>
        <span class="row-value" style="font-size:.78rem">${dayRangeStr}</span>
      </div>
      <div class="card-row">
        <span class="row-label">Open</span>
        <span class="row-value">${formatPrice(open)}</span>
      </div>
      <div class="card-row" style="border-bottom:none;padding-bottom:0">
        <span class="row-label">Prev Close</span>
        <span class="row-value">${formatPrice(prevClose)}</span>
      </div>
    </div>`;
  }

  function getUniverse() {
    return currentMode === 'crypto' ? CRYPTO_UNIVERSE : STOCK_UNIVERSE;
  }

  function applyFilters() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    let data = getUniverse().filter(s => {
      const catOk = currentCategory === 'all' || s.sector === currentCategory;
      const srchOk = !query || s.symbol.toLowerCase().includes(query) || s.name.toLowerCase().includes(query);
      return catOk && srchOk;
    });

    // Sort
    data.sort((a,b) => {
      let diff = 0;
      if (sortKey === 'price_high' || sortKey === 'price_low') diff = a.priceUSD - b.priceUSD;
      else if (sortKey === 'change_up' || sortKey === 'change_down') diff = a.change - b.change;
      else diff = b.priceUSD - a.priceUSD; // popular = by price desc
      return sortDir === 'desc' ? -diff || diff*-1 : diff;
    });

    filteredStocks = data;
    currentPage = 1;
    renderPage();
  }

  function renderPage() {
    const total   = filteredStocks.length;
    const pages   = Math.max(1, Math.ceil(total / PAGE_SIZE));
    const start   = (currentPage - 1) * PAGE_SIZE;
    const slice   = filteredStocks.slice(start, start + PAGE_SIZE);

    document.getElementById('resultsCount').innerHTML =
      `Showing <strong>${slice.length}</strong> of <strong>${total}</strong> stocks`;
    document.getElementById('pageInfo').innerHTML =
      `Page <strong>${currentPage}</strong> of <strong>${pages}</strong>`;
    document.getElementById('prevBtn').disabled = currentPage <= 1;
    document.getElementById('nextBtn').disabled = currentPage >= pages;

    const grid = document.getElementById('stocksGrid');
    if (!slice.length) {
      grid.innerHTML = `<div class="empty-state">
        <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <p>No stocks match your search.</p>
      </div>`;
    } else {
      grid.innerHTML = slice.map((s,i) => buildCard(s, i)).join('');
    }
    if (window._reattachCursor) window._reattachCursor();
  }

  function filterStocks() { applyFilters(); }

  function setCategory(btn, cat) {
    currentCategory = cat;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b === btn));
    applyFilters();
  }

  function sortStocks() {
    sortKey = document.getElementById('sortSelect').value;
    applyFilters();
  }

  function toggleSortDir() {
    sortDir = sortDir === 'desc' ? 'asc' : 'desc';
    document.getElementById('sortDirBtn').textContent = sortDir === 'desc' ? 'High → Low' : 'Low → High';
    applyFilters();
  }

  function changePage(dir) {
    const pages = Math.ceil(filteredStocks.length / PAGE_SIZE);
    currentPage = Math.max(1, Math.min(pages, currentPage + dir));
    renderPage();
    window.scrollTo({ top:0, behavior:'smooth' });
  }

  function changeCurrency() {
    currentCurrency = document.getElementById('currencySelect').value;
    renderPage();
  }

  function toggleMode(mode) {
    currentMode = mode;
    document.getElementById('cryptoToggle').classList.toggle('active', mode === 'crypto');
    document.getElementById('stocksToggle').classList.toggle('active', mode === 'stocks');
    // Reset category
    currentCategory = 'all';
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.cat === 'all'));
    applyFilters();
  }

  function viewStock(symbol) {
    window.location.href = `/stock/${symbol}`;
  }

  // ── Live price fetch (best-effort) ──────────────
  async function fetchLivePrice(symbol, idx) {
    try {
      const r = await fetch(`${BASE_URL}?function=GLOBAL_QUOTE&symbol=${symbol}&apikey=${API_KEY}`);
      const d = await r.json();
      const q = d['Global Quote'];
      if (!q || !q['05. price']) return;
      const i = STOCK_UNIVERSE.findIndex(s => s.symbol === symbol);
      if (i !== -1) {
        STOCK_UNIVERSE[i].priceUSD = parseFloat(q['05. price']);
        STOCK_UNIVERSE[i].change   = parseFloat(q['10. change percent']);
      }
      renderPage();
    } catch(_) {}
  }

  // ── Init ─────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    applyFilters();
    // Fetch live prices for top 5 (rate-limit friendly)
    const top5 = ['AAPL','MSFT','NVDA','META','TSLA'];
    top5.forEach((sym, i) => setTimeout(() => fetchLivePrice(sym, i), i * 1200));
  });
  </script>

</body>
</html>
