<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Nexus Login</title>

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #03040a;
  --neon: #00f5c4;
  --neon2: #7b61ff;
  --neon3: #ff6b6b;
  --text: #f0f0f0;
  --muted: rgba(240,240,240,0.5);
}

/* Base */
body {
  margin:0;
  height:100vh;
  background: var(--bg);
  font-family:'DM Sans', sans-serif;
  display:flex;
  justify-content:center;
  align-items:center;
  overflow:hidden;
  color:var(--text);
}

/* Aurora Background */
.aurora {
  position:fixed;
  inset:0;
  z-index:0;
}

.blob {
  position:absolute;
  border-radius:50%;
  filter:blur(90px);
  opacity:0.2;
  animation: drift 15s infinite alternate;
}

.blob:nth-child(1){
  width:500px;height:500px;
  background:var(--neon2);
  top:-100px;left:-100px;
}
.blob:nth-child(2){
  width:400px;height:400px;
  background:var(--neon);
  bottom:-100px;right:-100px;
}
.blob:nth-child(3){
  width:400px;height:300px;
  background:var(--neon3);
  top:50%;left:30%;
}

@keyframes drift {
  0%{transform:translate(0,0)}
  50%{transform:translate(60px,80px)}
  100%{transform:translate(-40px,30px)}
}

/* Login Card */
.login-box {
  position:relative;
  z-index:1;
  width:360px;
  padding:40px;
  border-radius:20px;
  background:rgba(255,255,255,0.05);
  backdrop-filter: blur(20px);
  border:1px solid rgba(255,255,255,0.1);
  box-shadow:0 0 40px rgba(0,245,196,0.15);
  animation: fadeUp 1s ease;
}

@keyframes fadeUp {
  from{opacity:0; transform:translateY(40px)}
  to{opacity:1; transform:translateY(0)}
}

.login-box h2 {
  font-family:'Syne', sans-serif;
  font-size:2rem;
  text-align:center;
  margin-bottom:30px;
}

/* Inputs */
.input-group {
  position:relative;
  margin-bottom:25px;
}

.input-group input {
  width:100%;
  padding:12px;
  background:transparent;
  border:none;
  border-bottom:2px solid var(--muted);
  color:var(--text);
  outline:none;
}

.input-group label {
  position:absolute;
  left:0;
  top:12px;
  color:var(--muted);
  transition:0.3s;
}

.input-group input:focus + label,
.input-group input:valid + label {
  top:-10px;
  font-size:12px;
  color:var(--neon);
}

/* Button */
button {
  width:100%;
  padding:12px;
  border:none;
  border-radius:10px;
  background: linear-gradient(135deg,var(--neon),var(--neon2));
  color:#000;
  font-weight:600;
  cursor:pointer;
  transition:0.3s;
}

button:hover {
  transform:scale(1.05);
  box-shadow:0 0 25px rgba(0,245,196,0.4);
}

/* Footer text */
.footer {
  text-align:center;
  margin-top:20px;
  font-size:0.9rem;
}

.footer a {
  color:var(--neon);
  text-decoration:none;
}
</style>

</head>

<body>

<!-- Aurora -->
<div class="aurora">
  <div class="blob"></div>
  <div class="blob"></div>
  <div class="blob"></div>
</div>

<!-- Login -->
<div class="login-box">
  <h2>Nexus Login</h2>

  <form action="/login" method="POST">
    <div class="input-group">
      <input type="text" name="email" required>
      <label>Username</label>
    </div>

    <div class="input-group">
      <input type="password" name='password' required>
      <label>Password</label>
    </div>

    <button>Login</button>

    <div class="footer">
      Don't have an account? <a href="/signup">Sign up</a>
    </div>
  </form>
</div>

</body>
</html>