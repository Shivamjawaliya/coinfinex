<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Market News — StockApp</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:#03040a; --neon:#00f5c4; --neon2:#7b61ff; --neon3:#ff6b6b;
      --text:#f0f0f0; --muted:rgba(240,240,240,0.5);
      --surface:rgba(255,255,255,0.03); --surface2:rgba(255,255,255,0.055);
      --border:rgba(255,255,255,0.07); --border-h:rgba(0,245,196,0.28);
      --card-r:18px;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;overflow-x:hidden;}
    body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden;cursor:none;min-height:100vh;}

    /* ── Cursor ───────────────────────────── */
    #cursor{position:fixed;width:10px;height:10px;border-radius:50%;background:var(--neon);pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:width .15s,height .15s;mix-blend-mode:difference;}
    #cursor-ring{position:fixed;width:36px;height:36px;border-radius:50%;border:1.5px solid var(--neon);pointer-events:none;z-index:99998;transform:translate(-50%,-50%);opacity:.5;transition:width .2s,height .2s;}

    /* ── BG ───────────────────────────────── */
    #particle-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}
    .grid-lines{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(0,245,196,0.028) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,196,0.028) 1px,transparent 1px);background-size:80px 80px;animation:gridMove 25s linear infinite;}
    @keyframes gridMove{0%{background-position:0 0}100%{background-position:80px 80px}}
    .aurora{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
    .blob{position:absolute;border-radius:50%;filter:blur(100px);opacity:.15;animation:float 15s infinite alternate;}
    .blob:nth-child(1){width:600px;height:600px;background:var(--neon2);top:-100px;left:-100px;animation-duration:15s;}
    .blob:nth-child(2){width:500px;height:500px;background:var(--neon);bottom:-100px;right:-100px;animation-duration:18s;animation-delay:-5s;}
    .blob:nth-child(3){width:400px;height:350px;background:var(--neon3);top:50%;left:30%;animation-duration:12s;animation-delay:-9s;}
    @keyframes float{0%{transform:translate(0,0) scale(1)}50%{transform:translate(80px,60px) scale(1.08)}100%{transform:translate(-40px,40px) scale(.95)}}

    /* ── Nav ──────────────────────────────── */
    nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:0 2%;backdrop-filter:blur(20px);background:rgba(0,0,0,.5);border-bottom:1px solid var(--border);height:60px;animation:navIn .6s ease both;}
    @keyframes navIn{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
    .nav-left{display:flex;align-items:center;}
    .nav-brand{display:flex;align-items:center;gap:10px;padding:0 20px;border-right:1px solid var(--border);height:60px;text-decoration:none;}
    .nav-brand-icon{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-family:'Syne';font-size:.8rem;font-weight:800;color:#03040a;}
    .nav-brand-text{font-family:'Syne';font-size:1rem;font-weight:800;color:var(--text);}
    .nav-tabs{display:flex;align-items:center;height:60px;}
    .nav-tab{display:flex;align-items:center;height:100%;padding:0 22px;text-decoration:none;font-size:.88rem;color:var(--muted);border-bottom:2px solid transparent;transition:color .25s,border-color .25s;white-space:nowrap;}
    .nav-tab:hover{color:var(--text);}
    .nav-tab.active{color:var(--neon);border-bottom-color:var(--neon);}
    .nav-right{display:flex;align-items:center;gap:10px;}
    .nav-divider{width:1px;height:28px;background:var(--border);}
    .tb-user{display:flex;align-items:center;gap:10px;padding:6px 14px 6px 8px;background:rgba(255,255,255,.05);border:1px solid var(--border);border-radius:8px;cursor:none;transition:all .25s;text-decoration:none;}
    .tb-user:hover{border-color:var(--neon);}
    .tb-avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;color:#03040a;flex-shrink:0;}
    .tb-name{font-size:.82rem;color:var(--text);}
    .nav-logout{width:36px;height:36px;border-radius:8px;background:rgba(255,107,107,.08);border:1px solid rgba(255,107,107,.2);display:flex;align-items:center;justify-content:center;cursor:none;transition:all .25s;color:var(--neon3);text-decoration:none;}
    .nav-logout:hover{background:rgba(255,107,107,.15);border-color:var(--neon3);}

    /* ── Page ─────────────────────────────── */
    .page{position:relative;z-index:1;max-width:1400px;margin:0 auto;padding:80px 32px 64px;}

    /* ── Hero ─────────────────────────────── */
    .hero{margin-bottom:40px;animation:fadeUp .7s ease both;}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;border:1px solid rgba(0,245,196,.25);background:rgba(0,245,196,.06);font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--neon);margin-bottom:16px;}
    .live-dot{width:7px;height:7px;border-radius:50%;background:var(--neon);animation:pulse 1.8s infinite;}
    @keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,245,196,.4)}50%{opacity:.7;box-shadow:0 0 0 5px rgba(0,245,196,0)}}
    .hero-title{font-family:'Syne';font-size:clamp(2rem,4vw,3.2rem);font-weight:800;line-height:1.1;margin-bottom:12px;background:linear-gradient(90deg,var(--text),var(--neon),var(--neon2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
    .hero-sub{color:var(--muted);font-size:.95rem;max-width:540px;}

    /* ── Filter bar ───────────────────────── */
    .filter-bar{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:32px;padding:14px 18px;background:var(--surface);border:1px solid var(--border);border-radius:14px;animation:fadeUp .7s .1s ease both;opacity:0;}
    .filter-label{font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-right:4px;white-space:nowrap;}
    .filter-chip{padding:7px 16px;border-radius:999px;border:1px solid var(--border);background:transparent;color:var(--muted);font-family:'DM Sans';font-size:.8rem;font-weight:600;cursor:none;transition:all .2s;white-space:nowrap;}
    .filter-chip:hover,.filter-chip.active{border-color:rgba(0,245,196,.4);color:var(--neon);background:rgba(0,245,196,.08);}
    .filter-sep{width:1px;height:24px;background:var(--border);flex-shrink:0;}
    .search-news-wrap{position:relative;flex:1;min-width:180px;}
    .search-news-wrap svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted);width:15px;height:15px;pointer-events:none;}
    .search-news{width:100%;background:rgba(0,0,0,.4);border:1px solid var(--border);border-radius:10px;padding:9px 14px 9px 36px;color:var(--text);font-family:'DM Sans';font-size:.85rem;outline:none;transition:all .2s;}
    .search-news::placeholder{color:var(--muted);}
    .search-news:focus{border-color:var(--neon);box-shadow:0 0 18px rgba(0,245,196,.1);}

    /* ── Stats strip ──────────────────────── */
    .stats-strip{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:32px;animation:fadeUp .7s .15s ease both;opacity:0;}
    .stat-pill{display:flex;align-items:center;gap:10px;padding:12px 18px;background:var(--surface);border:1px solid var(--border);border-radius:12px;transition:border-color .25s;}
    .stat-pill:hover{border-color:var(--border-h);}
    .stat-pill-icon{font-size:1.1rem;}
    .stat-pill-info{}
    .stat-pill-val{font-family:'Syne';font-size:1.1rem;font-weight:800;color:var(--neon);line-height:1;}
    .stat-pill-lbl{font-size:.68rem;color:var(--muted);letter-spacing:.05em;margin-top:2px;}

    /* ── Featured card ────────────────────── */
    .featured-wrap{margin-bottom:28px;animation:fadeUp .7s .2s ease both;opacity:0;}
    .featured-card{
      background:var(--surface);border:1px solid var(--border);border-radius:22px;
      overflow:hidden;display:grid;grid-template-columns:1.2fr 1fr;
      transition:border-color .35s,box-shadow .35s;position:relative;
    }
    .featured-card:hover{border-color:var(--border-h);box-shadow:0 28px 70px rgba(0,0,0,.5);}
    .featured-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--neon),var(--neon2));opacity:0;transition:opacity .3s;}
    .featured-card:hover::before{opacity:1;}
    .featured-thumb{width:100%;height:100%;min-height:280px;object-fit:cover;background:#0d1117;display:block;}
    .featured-thumb-placeholder{width:100%;min-height:280px;background:linear-gradient(135deg,rgba(0,245,196,.06),rgba(123,97,255,.06));display:flex;align-items:center;justify-content:center;font-size:4rem;}
    .featured-body{padding:32px;}
    .featured-tag{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:999px;background:rgba(0,245,196,.08);border:1px solid rgba(0,245,196,.2);font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--neon);margin-bottom:16px;}
    .featured-title{font-family:'Syne';font-size:1.55rem;font-weight:800;line-height:1.35;margin-bottom:14px;}
    .featured-title a{color:var(--text);text-decoration:none;transition:color .2s;}
    .featured-title a:hover{color:var(--neon);}
    .featured-summary{color:var(--muted);line-height:1.75;font-size:.9rem;margin-bottom:24px;}
    .featured-footer{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
    .featured-meta{display:flex;align-items:center;gap:10px;}
    .meta-dot{width:6px;height:6px;border-radius:50%;background:var(--muted);}
    .meta-txt{font-size:.78rem;color:var(--muted);}
    .read-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:10px;background:linear-gradient(135deg,var(--neon),var(--neon2));color:#03040a;text-decoration:none;font-weight:800;font-size:.82rem;transition:all .25s;white-space:nowrap;}
    .read-btn:hover{transform:scale(1.05);box-shadow:0 8px 24px rgba(0,245,196,.25);}
    .read-btn svg{width:14px;height:14px;}

    /* ── Sentiment badge ──────────────────── */
    .sent-badge{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:999px;font-size:.72rem;font-weight:700;}
    .sent-bull{background:rgba(0,230,118,.12);color:#00e676;border:1px solid rgba(0,230,118,.25);}
    .sent-bear{background:rgba(255,107,107,.12);color:#ff6b6b;border:1px solid rgba(255,107,107,.25);}
    .sent-neut{background:rgba(255,255,255,.06);color:var(--muted);border:1px solid var(--border);}

    /* ── News grid ────────────────────────── */
    .news-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px;margin-bottom:40px;}
    .news-card{
      background:var(--surface);border:1px solid var(--border);border-radius:var(--card-r);
      overflow:hidden;transition:transform .35s,border-color .35s,box-shadow .35s;
      display:flex;flex-direction:column;position:relative;
      animation:fadeUp .6s ease calc(var(--i,0)*.07s) both;opacity:0;
    }
    .news-card::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--neon),var(--neon2));opacity:0;transition:opacity .3s;}
    .news-card:hover{transform:translateY(-6px);border-color:var(--border-h);box-shadow:0 24px 60px rgba(0,0,0,.45);}
    .news-card:hover::after{opacity:1;}
    .thumb{width:100%;height:200px;object-fit:cover;background:#0d1117;display:block;}
    .thumb-placeholder{width:100%;height:200px;background:linear-gradient(135deg,rgba(0,245,196,.05),rgba(123,97,255,.05));display:flex;align-items:center;justify-content:center;font-size:3rem;}
    .card-body{padding:22px;flex:1;display:flex;flex-direction:column;gap:10px;}
    .source-row{display:flex;align-items:center;justify-content:space-between;gap:8px;}
    .source-tag{padding:4px 10px;border-radius:7px;background:rgba(123,97,255,.12);color:var(--neon2);font-size:.68rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;white-space:nowrap;}
    .card-title{font-size:1rem;font-weight:700;line-height:1.5;flex:1;}
    .card-title a{color:var(--text);text-decoration:none;transition:color .2s;}
    .card-title a:hover{color:var(--neon);}
    .card-summary{color:var(--muted);line-height:1.7;font-size:.86rem;}
    .card-footer{display:flex;justify-content:space-between;align-items:center;gap:8px;flex-wrap:wrap;margin-top:auto;padding-top:14px;border-top:1px solid var(--border);}
    .card-date{color:var(--muted);font-size:.75rem;}
    .card-read{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:9px;background:linear-gradient(135deg,rgba(0,245,196,.1),rgba(123,97,255,.1));border:1px solid rgba(0,245,196,.2);color:var(--neon);text-decoration:none;font-weight:700;font-size:.78rem;transition:all .25s;white-space:nowrap;}
    .card-read:hover{background:linear-gradient(135deg,rgba(0,245,196,.2),rgba(123,97,255,.2));transform:translateX(2px);}

    /* ── Pagination ───────────────────────── */
    .pagination{display:flex;justify-content:center;align-items:center;gap:10px;flex-wrap:wrap;animation:fadeUp .7s ease both;opacity:0;}
    .page-number,.page-btn{min-width:44px;height:44px;padding:0 16px;border-radius:11px;display:flex;align-items:center;justify-content:center;text-decoration:none;font-weight:700;font-size:.85rem;transition:all .25s;border:1px solid var(--border);background:var(--surface);color:var(--text);cursor:none;white-space:nowrap;}
    .page-number:hover,.page-btn:hover{border-color:var(--neon);color:var(--neon);transform:translateY(-2px);box-shadow:0 6px 20px rgba(0,245,196,.12);}
    .page-number.active{background:linear-gradient(135deg,var(--neon),var(--neon2));color:#03040a;border:none;box-shadow:0 6px 20px rgba(0,245,196,.25);}
    .page-btn:disabled{opacity:.35;pointer-events:none;}
    .page-ellipsis{color:var(--muted);font-size:.85rem;padding:0 4px;}

    /* ── Empty state ──────────────────────── */
    .empty{text-align:center;padding:80px 20px;color:var(--muted);grid-column:1/-1;}
    .empty-icon{font-size:3.5rem;margin-bottom:16px;opacity:.5;}
    .empty-text{font-size:1rem;}

    /* ── Animations ───────────────────────── */
    @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

    /* ── Responsive ───────────────────────── */
    @media(max-width:900px){.featured-card{grid-template-columns:1fr;}.featured-thumb,.featured-thumb-placeholder{min-height:200px;}.nav-tabs .nav-tab:not(.active){display:none;}}
    @media(max-width:700px){.page{padding:76px 16px 48px;}.news-grid{grid-template-columns:1fr;}.stats-strip{gap:10px;}}
  </style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-ring"></div>
<div class="grid-lines"></div>
<div class="aurora">
  <div class="blob"></div><div class="blob"></div><div class="blob"></div>
</div>
<canvas id="particle-canvas"></canvas>

<!-- ── Nav ──────────────────────────────── -->
<nav>
  <div class="nav-left">
    <a href="/dashboard" class="nav-brand">
      <div class="nav-brand-icon">SM</div>
      <span class="nav-brand-text">StockMarket</span>
    </a>
    <div class="nav-tabs">
      <a href="/" class="nav-tab">Explore</a>
        <a href="/categories" class="nav-tab">Categories</a>
        <a href="/portfolio" class="nav-tab">Portfolio</a>
        <a href="/news" class="nav-tab active">News</a>
        <a href="/virtual-trading" class="nav-tab">Virtual Trading</a>
    </div>
  </div>
  <div class="nav-right">
    <% if (typeof user !== 'undefined' && user) { %>
      <a href="/dashboard" class="tb-user">
        <div class="tb-avatar"><%= user.email[0].toUpperCase() %></div>
        <span class="tb-name"><%= user.email %></span>
      </a>
      <div class="nav-divider"></div>
      <a href="/logout" class="nav-logout" title="Logout">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      </a>
    <% } %>
  </div>
</nav>

<!-- ── Page ──────────────────────────────── -->
<div class="page">

  <!-- Hero -->
  <div class="hero">
    <div class="hero-eyebrow"><span class="live-dot"></span> Live Feed</div>
    <h1 class="hero-title">Stock Market News</h1>
    <p class="hero-sub">Real-time financial headlines, market updates and trending stories from top sources.</p>
  </div>

  <!-- Filter bar -->
  <div class="filter-bar">
    <span class="filter-label">Filter:</span>
    <button class="filter-chip active" onclick="filterNews(this,'all')">All</button>
    <button class="filter-chip" onclick="filterNews(this,'bullish')">🟢 Bullish</button>
    <button class="filter-chip" onclick="filterNews(this,'bearish')">🔴 Bearish</button>
    <button class="filter-chip" onclick="filterNews(this,'neutral')">⚪ Neutral</button>
    <div class="filter-sep"></div>
    <div class="search-news-wrap">
      <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" class="search-news" id="newsSearch" placeholder="Search headlines..." oninput="searchNews()"/>
    </div>
  </div>

  <!-- Stats strip -->
  <div class="stats-strip">
    <div class="stat-pill">
      <div class="stat-pill-icon">📰</div>
      <div class="stat-pill-info">
        <div class="stat-pill-val"><%= news.length %></div>
        <div class="stat-pill-lbl">Articles this page</div>
      </div>
    </div>
    <div class="stat-pill">
      <div class="stat-pill-icon">🟢</div>
      <div class="stat-pill-info">
        <div class="stat-pill-val" style="color:#00e676"><%= news.filter(n=>(n.sentiment||'').toLowerCase().includes('bull')).length %></div>
        <div class="stat-pill-lbl">Bullish stories</div>
      </div>
    </div>
    <div class="stat-pill">
      <div class="stat-pill-icon">🔴</div>
      <div class="stat-pill-info">
        <div class="stat-pill-val" style="color:var(--neon3)"><%= news.filter(n=>(n.sentiment||'').toLowerCase().includes('bear')).length %></div>
        <div class="stat-pill-lbl">Bearish stories</div>
      </div>
    </div>
    <div class="stat-pill">
      <div class="stat-pill-icon">📄</div>
      <div class="stat-pill-info">
        <div class="stat-pill-val" style="color:var(--neon2)"><%= totalPages %></div>
        <div class="stat-pill-lbl">Total pages</div>
      </div>
    </div>
  </div>

  <!-- Featured first article -->
  <% if(news.length > 0) {
    const f = news[0];
    const fSent = (f.sentiment||'neutral').toLowerCase();
    const fBull = fSent.includes('bull');
    const fBear = fSent.includes('bear');
  %>
  <div class="featured-wrap">
    <div class="featured-card">
      <% if(f.thumbnail) { %>
        <img src="<%= f.thumbnail %>" class="featured-thumb" alt="<%= f.title %>" loading="lazy"/>
      <% } else { %>
        <div class="featured-thumb-placeholder">📊</div>
      <% } %>
      <div class="featured-body">
        <div class="featured-tag">
          ⭐ Featured Story
        </div>
        <div class="featured-title">
          <a href="<%= f.url %>" target="_blank" rel="noopener"><%= f.title %></a>
        </div>
        <div class="featured-summary"><%= f.summary %></div>
        <div class="featured-footer">
          <div class="featured-meta">
            <span class="meta-txt"><%= f.source %></span>
            <span class="meta-dot"></span>
            <span class="meta-txt"><%= f.published %></span>
            <span class="meta-dot"></span>
            <span class="sent-badge <%= fBull ? 'sent-bull' : fBear ? 'sent-bear' : 'sent-neut' %>">
              <%= fBull ? '▲' : fBear ? '▼' : '●' %> <%= f.sentiment || 'Neutral' %>
            </span>
          </div>
          <a href="<%= f.url %>" target="_blank" rel="noopener" class="read-btn">
            Read Article
            <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <!-- News grid (skip first = already featured) -->
  <div class="news-grid" id="newsGrid">
    <% if(news.length <= 1) { %>
    <div class="empty">
      <div class="empty-icon">📭</div>
      <div class="empty-text">No news articles found.</div>
    </div>
    <% } else { %>
    <% news.slice(1).forEach((item, idx) => {
      const sent = (item.sentiment||'neutral').toLowerCase();
      const isBull = sent.includes('bull');
      const isBear = sent.includes('bear');
    %>
    <div class="news-card" style="--i:<%= idx %>" data-sent="<%= sent %>" data-title="<%= item.title.toLowerCase() %>">
      <% if(item.thumbnail) { %>
        <img src="<%= item.thumbnail %>" class="thumb" alt="<%= item.title %>" loading="lazy"/>
      <% } else { %>
        <div class="thumb-placeholder">📰</div>
      <% } %>
      <div class="card-body">
        <div class="source-row">
          <span class="source-tag"><%= item.source %></span>
          <span class="sent-badge <%= isBull ? 'sent-bull' : isBear ? 'sent-bear' : 'sent-neut' %>">
            <%= isBull ? '▲' : isBear ? '▼' : '●' %> <%= item.sentiment || 'Neutral' %>
          </span>
        </div>
        <div class="card-title">
          <a href="<%= item.url %>" target="_blank" rel="noopener"><%= item.title %></a>
        </div>
        <div class="card-summary"><%= item.summary %></div>
        <div class="card-footer">
          <span class="card-date">🕐 <%= item.published %></span>
          <a href="<%= item.url %>" target="_blank" rel="noopener" class="card-read">
            Read More
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
    <% }) %>
    <% } %>
  </div>

  <!-- Pagination -->
  <div class="pagination">
    <% if(currentPage > 1) { %>
      <a href="/news?page=<%= currentPage-1 %>" class="page-btn">← Prev</a>
    <% } %>
    <% for(let i=1; i<=totalPages; i++) { %>
      <% if(i===1 || i===totalPages || Math.abs(i-currentPage)<=1) { %>
        <a href="/news?page=<%= i %>" class="page-number <%= currentPage===i ? 'active' : '' %>"><%= i %></a>
      <% } else if(Math.abs(i-currentPage)===2) { %>
        <span class="page-ellipsis">…</span>
      <% } %>
    <% } %>
    <% if(currentPage < totalPages) { %>
      <a href="/news?page=<%= currentPage+1 %>" class="page-btn">Next →</a>
    <% } %>
  </div>

</div>

<!-- ── Scripts ─────────────────────────────── -->
<script>
/* Cursor */
(() => {
  const dot=document.getElementById('cursor'),ring=document.getElementById('cursor-ring');
  let mx=0,my=0,rx=0,ry=0;
  document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;dot.style.left=mx+'px';dot.style.top=my+'px';});
  (function loop(){rx+=(mx-rx)*.12;ry+=(my-ry)*.12;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(loop);})();
  document.querySelectorAll('a,button,.news-card,.filter-chip,.page-number,.page-btn,.tb-user,.nav-logout').forEach(el=>{
    el.addEventListener('mouseenter',()=>{dot.style.width='20px';dot.style.height='20px';ring.style.width='52px';ring.style.height='52px';ring.style.opacity='.75';});
    el.addEventListener('mouseleave',()=>{dot.style.width='10px';dot.style.height='10px';ring.style.width='36px';ring.style.height='36px';ring.style.opacity='.5';});
  });
})();

/* Particles */
(() => {
  const canvas=document.getElementById('particle-canvas'),ctx=canvas.getContext('2d');
  let W,H;
  function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;}
  resize();window.addEventListener('resize',resize);
  const PAL=['#00f5c4','#7b61ff','#ff6b6b','rgba(240,240,240,.4)'];
  const pts=Array.from({length:90},()=>({x:Math.random()*window.innerWidth,y:Math.random()*window.innerHeight,r:Math.random()*1.3+.3,vx:(Math.random()-.5)*.33,vy:(Math.random()-.5)*.33,a:Math.random()*.3+.07,col:PAL[Math.floor(Math.random()*PAL.length)]}));
  let pmx=-9999,pmy=-9999;
  document.addEventListener('mousemove',e=>{pmx=e.clientX;pmy=e.clientY;});
  (function draw(){
    ctx.clearRect(0,0,W,H);
    for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){
      const d=Math.hypot(pts[i].x-pts[j].x,pts[i].y-pts[j].y);
      if(d<90){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);ctx.strokeStyle='#00f5c4';ctx.globalAlpha=(1-d/90)*.055;ctx.lineWidth=.6;ctx.stroke();}
    }
    pts.forEach(p=>{
      const dx=p.x-pmx,dy=p.y-pmy,d=Math.hypot(dx,dy);
      if(d<110){const f=((110-d)/110)*.46;p.vx+=(dx/d)*f;p.vy+=(dy/d)*f;}
      p.vx*=.982;p.vy*=.982;p.x+=p.vx;p.y+=p.vy;
      if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.globalAlpha=p.a;ctx.fillStyle=p.col;ctx.fill();
    });
    ctx.globalAlpha=1;requestAnimationFrame(draw);
  })();
})();

/* Filter by sentiment */
let activeFilter = 'all';
function filterNews(btn, filter) {
  activeFilter = filter;
  document.querySelectorAll('.filter-chip').forEach(b=>b.classList.toggle('active',b===btn));
  applyNewsFilter();
}

/* Search headlines */
function searchNews() { applyNewsFilter(); }

function applyNewsFilter() {
  const q = document.getElementById('newsSearch').value.toLowerCase().trim();
  const cards = document.querySelectorAll('.news-card');
  let visible = 0;
  cards.forEach(card => {
    const sent = card.dataset.sent || '';
    const title = card.dataset.title || '';
    const sentOk = activeFilter === 'all'
      || (activeFilter === 'bullish'  && sent.includes('bull'))
      || (activeFilter === 'bearish'  && sent.includes('bear'))
      || (activeFilter === 'neutral'  && !sent.includes('bull') && !sent.includes('bear'));
    const searchOk = !q || title.includes(q);
    const show = sentOk && searchOk;
    card.style.display = show ? '' : 'none';
    if(show) visible++;
  });
  // Show empty if none match
  const grid = document.getElementById('newsGrid');
  let emptyEl = grid.querySelector('.filter-empty');
  if(visible === 0) {
    if(!emptyEl){
      emptyEl=document.createElement('div');
      emptyEl.className='empty filter-empty';
      emptyEl.innerHTML='<div class="empty-icon">🔍</div><div class="empty-text">No articles match your filter.</div>';
      grid.appendChild(emptyEl);
    }
  } else {
    emptyEl?.remove();
  }
}
</script>

</body>
</html>
