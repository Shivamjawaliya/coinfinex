<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= data.overview.name %> — <%= data.symbol %></title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    :root {
      --bg:#03040a;
      --neon:#00f5c4;
      --neon2:#7b61ff;
      --neon3:#ff6b6b;
      --text:#f0f0f0;
      --muted:rgba(240,240,240,0.48);
      --surface:rgba(255,255,255,0.032);
      --surface2:rgba(255,255,255,0.06);
      --border:rgba(255,255,255,0.07);
      --up:#00e676;
      --dn:#ff4d6d;
      --card-r:18px;
    }

    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;overflow-x:hidden;}
    body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow-x:hidden;cursor:none;min-height:100vh;}

    /* ── Cursor ─────────────────────────── */
    #cursor{position:fixed;width:10px;height:10px;border-radius:50%;background:var(--neon);pointer-events:none;z-index:99999;transform:translate(-50%,-50%);transition:width .15s,height .15s;mix-blend-mode:difference;}
    #cursor-ring{position:fixed;width:36px;height:36px;border-radius:50%;border:1.5px solid var(--neon);pointer-events:none;z-index:99998;transform:translate(-50%,-50%);opacity:.5;transition:width .2s,height .2s;}

    /* ── Background ─────────────────────── */
    #particle-canvas{position:fixed;inset:0;z-index:0;pointer-events:none;}
    .grid-lines{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(0,245,196,0.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,196,0.025) 1px,transparent 1px);background-size:80px 80px;animation:gridMove 28s linear infinite;}
    @keyframes gridMove{0%{background-position:0 0}100%{background-position:80px 80px}}
    .aurora{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
    .blob{position:absolute;border-radius:50%;filter:blur(110px);opacity:.13;animation:float 16s infinite alternate;}
    .blob:nth-child(1){width:600px;height:600px;background:var(--neon2);top:-120px;left:-120px;animation-duration:16s;}
    .blob:nth-child(2){width:480px;height:480px;background:var(--neon);bottom:-80px;right:-80px;animation-duration:20s;animation-delay:-7s;}
    .blob:nth-child(3){width:360px;height:300px;background:var(--neon3);top:45%;left:28%;animation-duration:13s;animation-delay:-11s;}
    @keyframes float{0%{transform:translate(0,0) scale(1)}50%{transform:translate(70px,55px) scale(1.07)}100%{transform:translate(-35px,38px) scale(.96)}}

    /* ── Nav ────────────────────────────── */
    nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:0 2%;backdrop-filter:blur(22px);background:rgba(0,0,0,0.5);border-bottom:1px solid var(--border);height:60px;}
    .nav-brand{display:flex;align-items:center;gap:10px;padding:0 20px;border-right:1px solid var(--border);height:60px;text-decoration:none;}
    .nav-brand-icon{width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-family:'Syne';font-size:.8rem;font-weight:800;color:#03040a;}
    .nav-brand-text{font-family:'Syne';font-size:1rem;font-weight:800;color:var(--text);}
    .nav-breadcrumb{display:flex;align-items:center;gap:8px;padding-left:20px;font-size:.85rem;color:var(--muted);}
    .nav-breadcrumb a{color:var(--muted);text-decoration:none;transition:color .2s;}
    .nav-breadcrumb a:hover{color:var(--neon);}
    .nav-breadcrumb span{color:var(--border);}
    .nav-breadcrumb strong{color:var(--text);}
    .nav-right{display:flex;align-items:center;gap:10px;}
    .tb-user{display:flex;align-items:center;gap:10px;padding:6px 14px 6px 8px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:8px;cursor:none;transition:all .25s;text-decoration:none;}
    .tb-user:hover{border-color:var(--neon);}
    .tb-avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:800;color:#03040a;}
    .tb-name{font-size:.82rem;color:var(--text);}
    .nav-back{display:flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--muted);font-family:'DM Sans';font-size:.82rem;cursor:none;transition:all .25s;text-decoration:none;}
    .nav-back:hover{border-color:var(--neon);color:var(--neon);}

    /* ── Page ───────────────────────────── */
    .page{position:relative;z-index:1;padding:80px 0 80px;min-height:100vh;}
    .container{max-width:1360px;margin:0 auto;padding:0 32px;}

    /* ── Hero strip ─────────────────────── */
    .hero{display:grid;grid-template-columns:1fr auto;gap:24px;align-items:flex-start;padding:36px 0 28px;border-bottom:1px solid var(--border);margin-bottom:28px;animation:fadeUp .7s ease both;}
    .hero-left{display:flex;align-items:center;gap:20px;}
    .hero-logo{width:64px;height:64px;border-radius:16px;background:linear-gradient(135deg,var(--neon),var(--neon2));display:flex;align-items:center;justify-content:center;font-family:'Syne';font-size:1.2rem;font-weight:800;color:#03040a;flex-shrink:0;box-shadow:0 0 32px rgba(0,245,196,0.2);}
    .hero-symbol{font-family:'Syne';font-size:2rem;font-weight:800;line-height:1;}
    .hero-name{font-size:.9rem;color:var(--muted);margin-top:4px;}
    .hero-badges{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;}
    .badge{padding:4px 10px;border-radius:6px;font-size:.68rem;letter-spacing:1px;text-transform:uppercase;font-weight:600;background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--muted);}
    .badge.sector{background:rgba(123,97,255,0.1);border-color:rgba(123,97,255,0.3);color:var(--neon2);}
    .badge.exchange{background:rgba(0,245,196,0.08);border-color:rgba(0,245,196,0.25);color:var(--neon);}
    .hero-right{display:flex;flex-direction:column;align-items:flex-end;gap:10px;}
    .hero-price{font-family:'Syne';font-size:2.8rem;font-weight:800;line-height:1;color:var(--neon);}
    .hero-change{font-size:.95rem;font-weight:600;padding:6px 14px;border-radius:8px;}
    .hero-change.up{background:rgba(0,230,118,0.1);color:var(--up);border:1px solid rgba(0,230,118,0.25);}
    .hero-change.dn{background:rgba(255,77,109,0.1);color:var(--dn);border:1px solid rgba(255,77,109,0.25);}
    .hero-date{font-size:.75rem;color:var(--muted);}

    /* ── Buy strip ──────────────────────── */
    .buy-strip{display:flex;align-items:center;gap:16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--card-r);padding:20px 24px;margin-bottom:24px;animation:fadeUp .7s .1s ease both;opacity:0;}
    .buy-strip-info{flex:1;}
    .buy-strip-label{font-size:.72rem;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:4px;}
    .buy-strip-price{font-family:'Syne';font-size:1.5rem;font-weight:800;color:var(--neon);}
    .qty-wrap{display:flex;align-items:center;gap:8px;}
    .qty-btn{width:36px;height:36px;border-radius:8px;border:1px solid var(--border);background:rgba(255,255,255,0.05);color:var(--text);font-size:1.1rem;cursor:none;transition:all .2s;display:flex;align-items:center;justify-content:center;}
    .qty-btn:hover{border-color:var(--neon);color:var(--neon);}
    .qty-input{width:64px;text-align:center;background:rgba(0,0,0,0.4);border:1px solid var(--border);border-radius:8px;padding:8px;color:var(--text);font-family:'DM Sans';font-size:.95rem;outline:none;}
    .qty-input:focus{border-color:var(--neon);}
    .total-wrap{text-align:right;}
    .total-label{font-size:.72rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;}
    .total-value{font-family:'Syne';font-size:1.3rem;font-weight:800;color:var(--text);}
    .btn-buy{padding:14px 36px;border-radius:12px;background:linear-gradient(135deg,var(--neon),var(--neon2));color:#03040a;font-family:'Syne';font-size:.95rem;font-weight:800;border:none;cursor:none;transition:all .3s;letter-spacing:.5px;position:relative;overflow:hidden;white-space:nowrap;}
    .btn-buy::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.18),transparent);opacity:0;transition:opacity .2s;}
    .btn-buy:hover{transform:scale(1.04);box-shadow:0 0 36px rgba(0,245,196,0.35);}
    .btn-buy:hover::after{opacity:1;}
    .btn-watchlist{padding:14px 20px;border-radius:12px;border:1px solid rgba(123,97,255,0.4);background:rgba(123,97,255,0.08);color:var(--neon2);font-family:'DM Sans';font-size:.85rem;font-weight:600;cursor:none;transition:all .3s;white-space:nowrap;}
    .btn-watchlist:hover{background:rgba(123,97,255,0.18);box-shadow:0 0 24px rgba(123,97,255,0.2);}

    /* ── Main grid ──────────────────────── */
    .main-grid{display:grid;grid-template-columns:1fr 340px;gap:20px;margin-bottom:20px;}

    /* ── Glass card ─────────────────────── */
    .glass{background:var(--surface);border:1px solid var(--border);border-radius:var(--card-r);padding:24px;position:relative;overflow:hidden;animation:fadeUp .7s ease var(--delay,.2s) both;opacity:0;}
    .glass-title{font-family:'Syne';font-size:1rem;font-weight:700;color:var(--text);margin-bottom:20px;display:flex;align-items:center;gap:8px;}
    .glass-title::before{content:'';width:3px;height:16px;border-radius:2px;background:var(--neon);flex-shrink:0;}

    /* ── Chart panel ────────────────────── */
    .chart-panel{--delay:.2s;}
    .chart-tabs{display:flex;gap:6px;margin-bottom:20px;}
    .chart-tab{padding:7px 16px;border-radius:8px;font-size:.78rem;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:none;transition:all .25s;}
    .chart-tab:hover{border-color:rgba(0,245,196,0.3);color:var(--text);}
    .chart-tab.active{background:rgba(0,245,196,0.1);border-color:rgba(0,245,196,0.4);color:var(--neon);}
    .chart-wrap{height:320px;position:relative;}

    /* ── Stats grid ─────────────────────── */
    .stats-panel{--delay:.3s;}
    .stat-row{display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:1px solid var(--border);}
    .stat-row:last-child{border-bottom:none;padding-bottom:0;}
    .stat-label{font-size:.75rem;color:var(--muted);letter-spacing:.5px;}
    .stat-value{font-size:.9rem;font-weight:600;color:var(--text);}
    .stat-value.up{color:var(--up);}
    .stat-value.dn{color:var(--dn);}
    .stat-value.accent{color:var(--neon);}

    /* ── Metrics 4-col ──────────────────── */
    .metrics-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
    .metric-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;padding:18px 16px;animation:fadeUp .6s ease calc(var(--mi,0)*.07s + .4s) both;opacity:0;}
    .metric-label{font-size:.65rem;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px;}
    .metric-value{font-family:'Syne';font-size:1.35rem;font-weight:800;line-height:1.1;}
    .metric-value.up{color:var(--up);}
    .metric-value.dn{color:var(--dn);}
    .metric-sub{font-size:.72rem;color:var(--muted);margin-top:4px;}

    /* ── Company info ───────────────────── */
    .info-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px;}
    .info-panel{--delay:.35s;}
    .desc-panel{--delay:.4s;grid-column:1/-1;}
    .description{font-size:.88rem;color:var(--muted);line-height:1.8;}

    /* ── News ───────────────────────────── */
    .news-panel{--delay:.45s;}
    .news-item{display:flex;gap:14px;padding:14px 0;border-bottom:1px solid var(--border);}
    .news-item:last-child{border-bottom:none;}
    .news-dot{width:8px;height:8px;border-radius:50%;background:var(--neon2);flex-shrink:0;margin-top:5px;}
    .news-dot.Positive{background:var(--up);}
    .news-dot.Negative{background:var(--dn);}
    .news-dot.Neutral{background:var(--neon2);}
    .news-title{font-size:.88rem;font-weight:600;color:var(--text);margin-bottom:4px;line-height:1.4;}
    .news-title a{color:inherit;text-decoration:none;transition:color .2s;}
    .news-title a:hover{color:var(--neon);}
    .news-meta{font-size:.72rem;color:var(--muted);display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
    .news-sentiment{padding:2px 8px;border-radius:4px;font-size:.65rem;font-weight:600;text-transform:uppercase;}
    .news-sentiment.Positive{background:rgba(0,230,118,0.12);color:var(--up);}
    .news-sentiment.Negative{background:rgba(255,77,109,0.12);color:var(--dn);}
    .news-sentiment.Neutral{background:rgba(255,255,255,0.06);color:var(--muted);}

    /* ── 52W bar ────────────────────────── */
    .week52-wrap{margin:16px 0 4px;}
    .week52-bar{height:6px;border-radius:3px;background:rgba(255,255,255,0.08);position:relative;margin:8px 0;overflow:visible;}
    .week52-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--neon2),var(--neon));}
    .week52-dot{position:absolute;top:50%;transform:translateY(-50%);width:14px;height:14px;border-radius:50%;background:var(--neon);border:2px solid var(--bg);box-shadow:0 0 10px rgba(0,245,196,.5);}
    .week52-labels{display:flex;justify-content:space-between;font-size:.7rem;color:var(--muted);}

    /* ── No data ────────────────────────── */
    .no-data{text-align:center;padding:60px 20px;color:var(--muted);}
    .no-data p{font-size:.9rem;}

    @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}

    /* ── Responsive ─────────────────────── */
    @media(max-width:1100px){.main-grid{grid-template-columns:1fr;}.metrics-grid{grid-template-columns:repeat(2,1fr);}}
    @media(max-width:700px){.hero{grid-template-columns:1fr;gap:14px;}.hero-right{align-items:flex-start;}.buy-strip{flex-wrap:wrap;}.metrics-grid{grid-template-columns:1fr 1fr;}.info-grid{grid-template-columns:1fr;}.desc-panel{grid-column:1;}}
    @media(max-width:480px){.container{padding:0 16px;}.metrics-grid{grid-template-columns:1fr;}}
  </style>
</head>
<body>

  <div id="cursor"></div>
  <div id="cursor-ring"></div>
  <div class="grid-lines"></div>
  <div class="aurora"><div class="blob"></div><div class="blob"></div><div class="blob"></div></div>
  <canvas id="particle-canvas"></canvas>

  <!-- ── Nav ──────────────────────────────────── -->
  <nav>
    <div style="display:flex;align-items:center;">
      <a href="/" class="nav-brand">
        <div class="nav-brand-icon">SM</div>
        <span class="nav-brand-text">StockMarket</span>
      </a>
      <div class="nav-breadcrumb">
        <a href="/explore">Explore</a>
        <span>/</span>
        <strong><%= data.symbol %></strong>
      </div>
    </div>
    <div class="nav-right">
      <a href="/explore" class="nav-back">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        Back
      </a>
      <% if (typeof user !== 'undefined' && user && user.username) { %>
        <a href="/dashboard/<%= encodeURIComponent(user.username) %>" class="tb-user">
          <div class="tb-avatar"><%= user.username[0].toUpperCase() %></div>
          <span class="tb-name"><%= user.username %></span>
        </a>
      <% } %>
    </div>
  </nav>

  <!-- ── Page ──────────────────────────────────── -->
  <div class="page">
    <div class="container">

      <!-- ── Hero ─────────────────────────────── -->
      <%
        const isUp     = data.quote.change >= 0;
        const chgClass = isUp ? 'up' : 'dn';
        const chgSign  = isUp ? '▲ +' : '▼ ';
        const priceDisplay   = data.quote.price > 0 ? '$' + data.quote.price.toFixed(2) : 'N/A';
        const openDisplay    = data.quote.open  > 0 ? '$' + data.quote.open.toFixed(2)  : 'N/A';
        const highDisplay    = data.quote.high  > 0 ? '$' + data.quote.high.toFixed(2)  : 'N/A';
        const lowDisplay     = data.quote.low   > 0 ? '$' + data.quote.low.toFixed(2)   : 'N/A';
        const volumeDisplay  = data.quote.volume > 0 ? (data.quote.volume / 1e6).toFixed(2) + 'M' : 'N/A';

        /* Overview helpers */
        const mcap = data.overview.marketCap !== '—' && !isNaN(parseInt(data.overview.marketCap))
                     ? '$' + (parseInt(data.overview.marketCap) / 1e9).toFixed(2) + 'B'
                     : '—';
        const sharesOut = data.overview.sharesOutstanding !== '—' && !isNaN(parseInt(data.overview.sharesOutstanding))
                          ? (parseInt(data.overview.sharesOutstanding) / 1e9).toFixed(2) + 'B'
                          : '—';
        const analystTgt = data.overview.analystTarget !== '—' && !isNaN(parseFloat(data.overview.analystTarget))
                           ? '$' + parseFloat(data.overview.analystTarget).toFixed(2)
                           : '—';
        const epsDisplay = data.overview.eps !== '—' && !isNaN(parseFloat(data.overview.eps))
                           ? '$' + data.overview.eps
                           : '—';
        const revDisplay = data.overview.revenuePerShare !== '—' && !isNaN(parseFloat(data.overview.revenuePerShare))
                           ? '$' + data.overview.revenuePerShare
                           : '—';

        /* 52-week range bar */
        const hi52  = parseFloat(data.overview.week52High);
        const lo52  = parseFloat(data.overview.week52Low);
        const show52 = !isNaN(hi52) && !isNaN(lo52) && hi52 > 0 && lo52 > 0 && data.quote.price > 0;
        const pct52  = show52
          ? Math.min(100, Math.max(0, ((data.quote.price - lo52) / (hi52 - lo52)) * 100))
          : 50;
      %>

      <div class="hero">
        <div class="hero-left">
          <div class="hero-logo"><%= data.symbol.substring(0,2) %></div>
          <div class="hero-meta">
            <div class="hero-symbol"><%= data.symbol %></div>
            <div class="hero-name"><%= data.overview.name %></div>
            <div class="hero-badges">
              <% if (data.overview.exchange !== '—') { %>
                <span class="badge exchange"><%= data.overview.exchange %></span>
              <% } %>
              <% if (data.overview.sector !== '—') { %>
                <span class="badge sector"><%= data.overview.sector %></span>
              <% } %>
              <% if (data.overview.country !== '—') { %>
                <span class="badge"><%= data.overview.country %></span>
              <% } %>
              <span class="badge"><%= data.overview.currency %></span>
            </div>
          </div>
        </div>
        <div class="hero-right">
          <div class="hero-price"><%= priceDisplay %></div>
          <div class="hero-change <%= chgClass %>">
            <%= chgSign %><%= data.quote.change.toFixed(2) %> &nbsp; <%= data.quote.changePct %>
          </div>
          <div class="hero-date">As of <%= data.quote.latestDay %></div>
        </div>
      </div>

      <!-- ── Buy strip ──────────────────────────── -->
      <div class="buy-strip">
        <div class="buy-strip-info">
          <div class="buy-strip-label">Market Price</div>
          <div class="buy-strip-price"><%= priceDisplay %></div>
        </div>
        <div class="qty-wrap">
          <button class="qty-btn" onclick="adjustQty(-1)">−</button>
          <input type="number" id="qtyInput" class="qty-input" value="1" min="1" max="9999" oninput="updateTotal()"/>
          <button class="qty-btn" onclick="adjustQty(1)">+</button>
        </div>
        <div class="total-wrap">
          <div class="total-label">Total</div>
          <div class="total-value" id="totalValue"><%= priceDisplay %></div>
        </div>
        <button class="btn-buy" onclick="buystock()">Buy <%= data.symbol %></button>
        <button class="btn-watchlist" id="watchlistBtn" onclick="handleWatchlist()">♡ &nbsp;Watchlist</button>
      </div>

      <!-- ── Key metrics row ────────────────────── -->
      <div class="metrics-grid">
        <div class="metric-card" style="--mi:0">
          <div class="metric-label">Open</div>
          <div class="metric-value"><%= openDisplay %></div>
          <div class="metric-sub">Today's open</div>
        </div>
        <div class="metric-card" style="--mi:1">
          <div class="metric-label">Day High</div>
          <div class="metric-value up"><%= highDisplay %></div>
          <div class="metric-sub">Intraday high</div>
        </div>
        <div class="metric-card" style="--mi:2">
          <div class="metric-label">Day Low</div>
          <div class="metric-value dn"><%= lowDisplay %></div>
          <div class="metric-sub">Intraday low</div>
        </div>
        <div class="metric-card" style="--mi:3">
          <div class="metric-label">Volume</div>
          <div class="metric-value"><%= volumeDisplay %></div>
          <div class="metric-sub">Shares traded</div>
        </div>
      </div>

      <!-- ── Main grid: chart + sidebar ─────────── -->
      <div class="main-grid">

        <!-- Chart -->
        <div class="glass chart-panel">
          <div class="glass-title">Price History</div>
          <div class="chart-tabs">
            <button class="chart-tab" onclick="setRange(1)"    data-range="1">1D</button>
            <button class="chart-tab active" onclick="setRange(30)"  data-range="30">1M</button>
            <button class="chart-tab" onclick="setRange(90)"   data-range="90">3M</button>
            <button class="chart-tab" onclick="setRange(180)"  data-range="180">6M</button>
            <button class="chart-tab" onclick="setRange(365)"  data-range="365">1Y</button>
            <button class="chart-tab" onclick="setRange(9999)" data-range="9999">All</button>
          </div>
          <div class="chart-wrap">
            <canvas id="priceChart"></canvas>
          </div>
        </div>

        <!-- Stats sidebar -->
        <div class="glass stats-panel">
          <div class="glass-title">Trading Stats</div>

          <div class="stat-row">
            <span class="stat-label">Prev Close</span>
            <span class="stat-value">
              <%= data.quote.prevClose > 0 ? '$' + data.quote.prevClose.toFixed(2) : '—' %>
            </span>
          </div>
          <div class="stat-row">
            <span class="stat-label">52W High</span>
            <span class="stat-value up">
              <%= data.overview.week52High !== '—' ? '$' + data.overview.week52High : '—' %>
            </span>
          </div>
          <div class="stat-row">
            <span class="stat-label">52W Low</span>
            <span class="stat-value dn">
              <%= data.overview.week52Low !== '—' ? '$' + data.overview.week52Low : '—' %>
            </span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Market Cap</span>
            <span class="stat-value accent"><%= mcap %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">P/E Ratio</span>
            <span class="stat-value"><%= data.overview.pe %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">EPS</span>
            <span class="stat-value"><%= epsDisplay %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Beta</span>
            <span class="stat-value"><%= data.overview.beta %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Dividend Yield</span>
            <span class="stat-value"><%= data.overview.divYield %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Analyst Target</span>
            <span class="stat-value accent"><%= analystTgt %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Profit Margin</span>
            <span class="stat-value"><%= data.overview.profitMargin %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Shares Out.</span>
            <span class="stat-value"><%= sharesOut %></span>
          </div>

          <!-- 52W range bar -->
          <% if (show52) { %>
          <div class="week52-wrap">
            <div class="stat-label" style="margin-bottom:6px;">52-Week Range</div>
            <div class="week52-bar">
              <div class="week52-fill" style="width:<%= pct52.toFixed(1) %>%"></div>
              <div class="week52-dot"  style="left:calc(<%= pct52.toFixed(1) %>% - 7px)"></div>
            </div>
            <div class="week52-labels">
              <span>$<%= lo52.toFixed(2) %></span>
              <span>$<%= hi52.toFixed(2) %></span>
            </div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- ── Company info + description ─────────── -->
      <div class="info-grid">
        <div class="glass info-panel">
          <div class="glass-title">Company Info</div>
          <div class="stat-row">
            <span class="stat-label">Industry</span>
            <span class="stat-value" style="text-align:right;max-width:55%;font-size:.82rem"><%= data.overview.industry %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Exchange</span>
            <span class="stat-value"><%= data.overview.exchange %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Country</span>
            <span class="stat-value"><%= data.overview.country %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Currency</span>
            <span class="stat-value"><%= data.overview.currency %></span>
          </div>
          <div class="stat-row">
            <span class="stat-label">Revenue/Share</span>
            <span class="stat-value"><%= revDisplay %></span>
          </div>
        </div>

        <div class="glass desc-panel">
          <div class="glass-title">About <%= data.overview.name %></div>
          <% if (data.overview.description && data.overview.description.length > 0) { %>
            <p class="description"><%= data.overview.description %></p>
          <% } else { %>
            <p class="description" style="font-style:italic;">No description available for this company.</p>
          <% } %>
        </div>
      </div>

      <!-- ── News ───────────────────────────────── -->
      <div class="glass news-panel">
        <div class="glass-title">Latest News</div>
        <% if (data.news && data.news.length > 0) { %>
          <% data.news.forEach(function(n) { %>
            <div class="news-item">
              <!-- dot colour driven by sentimentClass set in the route -->
              <div class="news-dot <%= n.sentimentClass %>"></div>
              <div class="news-content">
                <div class="news-title">
                  <a href="<%= n.url %>" target="_blank" rel="noopener"><%= n.title %></a>
                </div>
                <div class="news-meta">
                  <span><%= n.source %></span>
                  <% if (n.published) { %>
                    <span>·</span>
                    <span><%= n.published %></span>
                  <% } %>
                  <span class="news-sentiment <%= n.sentimentClass %>"><%= n.sentimentLabel %></span>
                </div>
                <% if (n.summary && n.summary.length > 0) { %>
                  <p style="font-size:.8rem;color:var(--muted);margin-top:6px;line-height:1.6;"><%= n.summary %>…</p>
                <% } %>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="no-data"><p>No recent news found for <%= data.symbol %>.</p></div>
        <% } %>
      </div>

    </div><!-- /container -->
  </div><!-- /page -->

  <!-- ── Scripts ────────────────────────────────── -->
  <script>
  /* Injected server data — safe JSON serialisation */
  const HISTORY = <%- JSON.stringify(data.history) %>;
  const SYMBOL  = '<%- data.symbol %>';
  const PRICE   = <%= data.quote.price %>;

  /* ── Custom cursor ──────────────────────────── */
  (() => {
    const dot  = document.getElementById('cursor');
    const ring = document.getElementById('cursor-ring');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      dot.style.left = mx + 'px'; dot.style.top = my + 'px';
    });
    (function loop() {
      rx += (mx - rx) * .12; ry += (my - ry) * .12;
      ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
      requestAnimationFrame(loop);
    })();
    document.querySelectorAll('a, button, input').forEach(el => {
      el.addEventListener('mouseenter', () => {
        dot.style.width = dot.style.height = '20px';
        ring.style.width = ring.style.height = '52px';
        ring.style.opacity = '.75';
      });
      el.addEventListener('mouseleave', () => {
        dot.style.width = dot.style.height = '10px';
        ring.style.width = ring.style.height = '36px';
        ring.style.opacity = '.5';
      });
    });
  })();

  /* ── Particle canvas ────────────────────────── */
  (() => {
    const c = document.getElementById('particle-canvas');
    const ctx = c.getContext('2d');
    let W, H;
    function resize() { W = c.width = window.innerWidth; H = c.height = window.innerHeight; }
    resize(); window.addEventListener('resize', resize);
    const PAL = ['#00f5c4','#7b61ff','#ff6b6b'];
    const pts = Array.from({ length: 80 }, () => ({
      x: Math.random() * W, y: Math.random() * H,
      r: Math.random() * 1.3 + .3,
      vx: (Math.random() - .5) * .3, vy: (Math.random() - .5) * .3,
      a: Math.random() * .3 + .07,
      col: PAL[Math.floor(Math.random() * 3)],
    }));
    let pmx = -9999, pmy = -9999;
    document.addEventListener('mousemove', e => { pmx = e.clientX; pmy = e.clientY; });
    (function draw() {
      ctx.clearRect(0, 0, W, H);
      for (let i = 0; i < pts.length; i++) for (let j = i + 1; j < pts.length; j++) {
        const d = Math.hypot(pts[i].x - pts[j].x, pts[i].y - pts[j].y);
        if (d < 90) {
          ctx.beginPath(); ctx.moveTo(pts[i].x, pts[i].y); ctx.lineTo(pts[j].x, pts[j].y);
          ctx.strokeStyle = '#00f5c4'; ctx.globalAlpha = (1 - d / 90) * .05;
          ctx.lineWidth = .6; ctx.stroke();
        }
      }
      pts.forEach(p => {
        const dx = p.x - pmx, dy = p.y - pmy, d = Math.hypot(dx, dy);
        if (d < 100) { const f = ((100 - d) / 100) * .45; p.vx += (dx / d) * f; p.vy += (dy / d) * f; }
        p.vx *= .98; p.vy *= .98; p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > W) p.vx *= -1;
        if (p.y < 0 || p.y > H) p.vy *= -1;
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.globalAlpha = p.a; ctx.fillStyle = p.col; ctx.fill();
      });
      ctx.globalAlpha = 1;
      requestAnimationFrame(draw);
    })();
  })();

  /* ── Chart ──────────────────────────────────── */
  let priceChart = null;

  function buildChartData(days) {
    const slice = days >= 9999
      ? [...HISTORY].reverse()
      : [...HISTORY].slice(0, days).reverse();
    return {
      labels: slice.map(h => {
        const d = new Date(h.date);
        return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      }),
      prices: slice.map(h => h.close),
    };
  }

  function getChartColor(prices) {
    if (!prices.length) return '#00f5c4';
    return prices[prices.length - 1] >= prices[0] ? '#00f5c4' : '#ff4d6d';
  }

  function initChart(days) {
    const { labels, prices } = buildChartData(days);
    const color = getChartColor(prices);
    const canvas = document.getElementById('priceChart');
    const ctx = canvas.getContext('2d');
    const gradient = ctx.createLinearGradient(0, 0, 0, 320);
    gradient.addColorStop(0, color === '#00f5c4' ? 'rgba(0,245,196,0.18)' : 'rgba(255,77,109,0.18)');
    gradient.addColorStop(1, 'rgba(0,0,0,0)');
    if (priceChart) priceChart.destroy();
    priceChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: SYMBOL + ' Close',
          data: prices,
          borderColor: color,
          backgroundColor: gradient,
          borderWidth: 2,
          pointRadius: 0,
          pointHoverRadius: 5,
          pointHoverBackgroundColor: color,
          tension: 0.35,
          fill: true,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { intersect: false, mode: 'index' },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#0d0f1a',
            borderColor: 'rgba(255,255,255,0.08)',
            borderWidth: 1,
            titleColor: color,
            bodyColor: '#f0f0f0',
            titleFont: { family: 'DM Sans', size: 11 },
            bodyFont: { family: 'DM Sans', size: 13, weight: '600' },
            padding: 12,
            callbacks: { label: ctx => ' $' + ctx.parsed.y.toFixed(2) },
          },
        },
        scales: {
          x: {
            grid: { color: 'rgba(255,255,255,0.04)', drawBorder: false },
            ticks: { color: 'rgba(240,240,240,0.35)', font: { family: 'DM Sans', size: 10 }, maxTicksLimit: 8, maxRotation: 0 },
          },
          y: {
            position: 'right',
            grid: { color: 'rgba(255,255,255,0.04)', drawBorder: false },
            ticks: {
              color: 'rgba(240,240,240,0.35)',
              font: { family: 'DM Sans', size: 10 },
              callback: v => '$' + v.toLocaleString('en-US', { maximumFractionDigits: 2 }),
            },
          },
        },
      },
    });
  }

  function setRange(days) {
    document.querySelectorAll('.chart-tab').forEach(t => {
      t.classList.toggle('active',
        parseInt(t.dataset.range) === days || (days >= 9999 && t.dataset.range === '9999')
      );
    });
    initChart(days);
  }

  /* ── Buy logic ──────────────────────────────── */
  const stockPrice = PRICE;

  function adjustQty(delta) {
    const input = document.getElementById('qtyInput');
    input.value = Math.max(1, parseInt(input.value || 1) + delta);
    updateTotal();
  }

  function updateTotal() {
    const qty   = Math.max(1, parseInt(document.getElementById('qtyInput').value) || 1);
    const total = (qty * stockPrice).toFixed(2);
    document.getElementById('totalValue').textContent =
      '$' + parseFloat(total).toLocaleString('en-US', { minimumFractionDigits: 2 });
  }

  function handleBuy() {
    const qty   = parseInt(document.getElementById('qtyInput').value) || 1;
    const total = (qty * stockPrice).toFixed(2);

    alert(`Order placed!\n${qty} × ${SYMBOL} @ $${stockPrice.toFixed(2)}\nTotal: $${parseFloat(total).toLocaleString('en-US')}`);
  }
    function buystock(){

    // REMOVE OLD MODAL
    const oldModal =
    document.getElementById('buyModal');

    if(oldModal){

    oldModal.remove();
    }

    // CREATE MODAL
    const modal =
    document.createElement('div');

    modal.id = 'buyModal';

    modal.style.cssText = `

    position:fixed;
    inset:0;
    background:rgba(0,0,0,0.7);
    display:flex;
    justify-content:center;
    align-items:center;
    z-index:99999;
    backdrop-filter:blur(10px);

    `;

    // TOTAL PRICE
    const total =
    stockPrice.toFixed(2);

    // MODAL HTML
    modal.innerHTML = `

    <div style="

        width:420px;
        background:#0f172a;
        border:1px solid rgba(255,255,255,0.08);
        border-radius:24px;
        padding:30px;
        color:white;
        font-family:sans-serif;

    ">

        <!-- HEADER -->

        <div style="
        display:flex;
        justify-content:space-between;
        align-items:center;
        margin-bottom:24px;
        ">

        <h2 style="
            font-size:28px;
            margin:0;
        ">

            Buy

            <span style="
            color:#00f5c4;
            ">

            ${SYMBOL}

            </span>

        </h2>

        <button
            id="closeBuyModalBtn"
            style="

            width:40px;
            height:40px;
            border:none;
            border-radius:12px;
            background:rgba(255,255,255,0.06);
            color:white;
            cursor:pointer;
            font-size:18px;

            "
        >

            ✕

        </button>

        </div>

        <!-- PRICE -->

        <div style="
        background:rgba(255,255,255,0.04);
        border-radius:16px;
        padding:18px;
        margin-bottom:18px;
        ">

        <div style="
            font-size:13px;
            color:rgba(255,255,255,0.5);
            margin-bottom:8px;
            text-transform:uppercase;
        ">

            Current Price

        </div>

        <div style="
            font-size:24px;
            font-weight:700;
            color:#00f5c4;
        ">

            $${stockPrice.toFixed(2)}

        </div>

        </div>

        <!-- QUANTITY -->

        <div style="
        background:rgba(255,255,255,0.04);
        border-radius:16px;
        padding:18px;
        margin-bottom:18px;
        ">

        <div style="
            font-size:13px;
            color:rgba(255,255,255,0.5);
            margin-bottom:8px;
            text-transform:uppercase;
        ">

            Quantity

        </div>

        <input
            type="number"
            id="buyQty"
            min="1"
            value="1"

            style="
            width:100%;
            margin-top:10px;
            padding:14px;
            border:none;
            border-radius:14px;
            background:#111827;
            color:white;
            font-size:18px;
            outline:none;
            "
        >

        </div>

        <!-- TOTAL -->

        <div
        id="buyTotalBox"

        style="
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:24px;
            padding:18px;
            border-radius:16px;
            background:
            linear-gradient(
                135deg,
                rgba(0,245,196,0.08),
                rgba(123,97,255,0.08)
            );
        "
        >

        <span>

            Total Amount

        </span>

        <strong
            id="buyTotal"
            style="
            font-size:28px;
            "
        >

            $${total}

        </strong>

        </div>

        <!-- BUTTON -->

        <button
        id="confirmBuyBtn"

        style="
            width:100%;
            padding:16px;
            border:none;
            border-radius:16px;
            background:
            linear-gradient(
                135deg,
                #00f5c4,
                #7b61ff
            );
            color:#03040a;
            font-weight:800;
            font-size:16px;
            cursor:pointer;
        "
        >

        Confirm Purchase

        </button>

    </div>

    `;

    // APPEND
    document.body.appendChild(modal);

    // QUANTITY UPDATE
    const qtyInput =
    document.getElementById('buyQty');

    qtyInput.addEventListener(
    'input',
    () => {

        const qty =
        parseInt(qtyInput.value) || 1;

        const total =
        qty * stockPrice;

        document
        .getElementById('buyTotal')
        .innerText =
            '$' + total.toFixed(2);
    }
    );

    // CLOSE MODAL
    document
    .getElementById('closeBuyModalBtn')
    .addEventListener(
        'click',
        () => {

        modal.remove();
        }
    );

    // CONFIRM BUY
    document
    .getElementById('confirmBuyBtn')
    .addEventListener(
        'click',
        async () => {

        try {

            const qty =
            parseInt(qtyInput.value) || 1;

            if(qty <= 0){

            showNotification(
                'Invalid Quantity'
            );

            return;
            }

            const response =
            await fetch('/buy-stock', {

                method:'POST',

                headers:{
                'Content-Type':
                    'application/json'
                },

                body: JSON.stringify({

                stockname:
                    SYMBOL,

                stockquantity:
                    qty,

                stockbuyprice:
                    stockPrice

                })

            });

            const data =
            await response.json();

            if(data.success){

            modal.remove();

            showNotification(
                'Stock Purchased Successfully'
            );

            } else {

            showNotification(
                'Purchase Failed'
            );
            }

        } catch(err){

            console.log(err);

            showNotification(
            'Something went wrong'
            );
        }
        }
    );
    }

    // =====================================
    // NOTIFICATION
    // =====================================

    function showNotification(message){

    let notification =
    document.getElementById('notification');

    // CREATE NOTIFICATION
    if(!notification){

    notification =
        document.createElement('div');

    notification.id =
        'notification';

    notification.style.cssText = `

        position:fixed;
        bottom:30px;
        left:50%;
        transform:translateX(-50%);
        background:#10b981;
        color:white;
        padding:16px 26px;
        border-radius:16px;
        font-weight:700;
        z-index:999999;
        opacity:0;
        transition:0.4s;

    `;

    document.body.appendChild(
        notification
    );
    }

    notification.innerText =
    message;

    notification.style.opacity = '1';

    setTimeout(() => {

    notification.style.opacity = '0';

    }, 3000);
    }

  function handleWatchlist() {
    const btn = document.getElementById('watchlistBtn');
    btn.textContent  = '♥  Watching';
    btn.style.borderColor = 'rgba(0,230,118,.4)';
    btn.style.background  = 'rgba(0,230,118,.08)';
    btn.style.color       = 'var(--up)';
    fetch(`/watchlist/add/${SYMBOL}`, { method: 'POST' }).catch(() => {});
  }

  /* ── Boot ───────────────────────────────────── */
  document.addEventListener('DOMContentLoaded', () => {
    if (HISTORY && HISTORY.length > 0) {
      initChart(30);
    } else {
      document.querySelector('.chart-wrap').innerHTML =
        '<div class="no-data"><p>Chart data unavailable for ' + SYMBOL + '.</p></div>';
    }
    updateTotal();
  });
  </script>

</body>
</html>
